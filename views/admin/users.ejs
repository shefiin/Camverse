<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>User Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-slate-50" style="font-family: 'Kanit', sans-serif;">
    
    <%- include('partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full relative">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
              <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">User Management</h1>
              <p class="text-sm text-slate-500 mt-2">Search and manage user access with quick moderation actions.</p>
            </div>


            <div class="flex justify-between items-center mb-6 border border-slate-200 bg-white p-4 shadow-sm">
              
              <div class="flex items-center space-x-1">
                <div class="relative w-64 md:w-96">
                    <form
                    action="/admin/users"
                    method="GET"
                    class="relative flex items-center"
                  >
                    <input
                      type="text"
                      name="search"
                      value="<%= typeof search !== 'undefined' ? search : '' %>"
                      placeholder="Search users..."
                      class="pl-3 py-2 border border-gray-300 px-4 w-64 md:w-96 focus:outline-none focus:ring focus:border-none focus:ring-blue-200"
                    >
                
                    <button
                      type="submit"
                      class="absolute inset-y-0 right-0 m-1 p-3 flex items-center bg-gray-200 text-gray-600 hover:text-blue-600 active:scale-[0.95] transition duration-150 ease-out transform">
                      <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                
                  </form>
                </div>
                <% if (search) { %>
                    <a
                      href="/admin/users"
                      class="text-sm text-gray-500 hover:text-gray-600 bg-gray-200 hover:bg-gray-300 px-1 py-3"
                      title="Clear Search"
                    >
                      Clear
                    </a>
                  <% } %>
            </div>
              

                <!-- <a href="/admin/user/add" 
                    class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 shadow">
                    <i class="fa-solid fa-plus"></i>
                    Add User
                </a> -->
            </div>

            <div class="bg-slate-900 border border-slate-700 shadow p-4 md:p-5 mt-6">
                <h2 class="text-white text-lg font-semibold mb-4">Users</h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-left text-sm text-gray-100">
                            <thead class="bg-slate-800 text-slate-100 text-sm md:text-base">
                                <tr>
                                    <th class="px-4 py-3">No</th>
                                    <th class="px-4 py-3">Image</th>
                                    <th class="px-4 py-3">User Name</th>
                                    <th class="px-4 py-3">Email</th>
                                    <th class="px-4 py-3">Mobile</th>
                                    <th class="px-4 py-3">Status</th>
                                    <th class="px-4 text-center py-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-700">
                              <% users.forEach((user, index) => { %>
                                <tr class="hover:bg-slate-800/80">
                                  <td class="px-4 py-2"><%= skip + index + 1 %></td>
                                  <td class="px-4 py-2">
                                    <% if (user.profileImage) { %>
                                      <img src="<%= user.profileImage %>" 
                                           alt="<%= user.name %>" 
                                           class="object-contain w-14 h-14">
                                    <% } else { %>
                                      <div class="w-14 h-14 p-1 bg-gray-500 text-center">
                                        <i class="fa-solid fa-user text-3xl mt-2"></i>
                                      </div>
                                    <% } %>
                                  </td>                                  
                                  <td class="px-4 py-2"><%= user.name %></td>
                                  <td class="px-4 py-2"><%= user.email %></td>
                                  <td class="px-4 py-2">
                                    <% if (user.addresses && user.addresses.length > 0) { %>
                                      <%= user.addresses[0].mobile %>
                                    <% } else { %>
                                      N/A
                                    <% } %>
                                  </td>
                                  <td class="px-4 py-2">
                                    <% if (user.status === 'Active') { %>
                                        <span class="px-4 py-1 rounded-full text-green-400 bg-green-900/40 text-sm">Active</span>
                                    <% } else if (user.status === 'Blocked') { %>
                                        <span class="px-4 py-1 rounded-full text-red-400 bg-red-900/40 text-sm">Blocked</span>
                                    <% } %>
                                  </td>
                                  <td class="px-4 py-2 text-center space-y-2">
                                    
                                    <% if (user.isBlocked) { %>
                                      <form action="/admin/users/unblock/<%= user._id %>?_method=PATCH" method="POST" class="inline-block block-form">
                                        <button type="submit" class="px-3 py-1 bg-green-600 text-white hover:bg-green-700 active:scale-[0.95] transition duration-150 ease-out transform">
                                          Unblock
                                        </button>
                                      </form>
                                    <% } else { %>
                                      <form action="/admin/users/block/<%= user._id %>?_method=PATCH" method="POST" class="inline-block block-form">
                                        <button type="submit" class="px-3 py-1 bg-red-600 text-white hover:bg-red-700 active:scale-[0.95] transition duration-150 ease-out transform">
                                          Block
                                        </button>
                                      </form>
                                    <% } %>

                                    </div>
                                  </td>
                                                                                                                                                           
                              </tr>
                              <% }); %>
                            </tbody>
                        </table>
                    </div>
            </div>
            <%- include('partials/pagination') %>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('sidebar');

        menuBtn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        })

        document.querySelectorAll('.block-form').forEach(form => {
        form.addEventListener('submit', function (e) {
          e.preventDefault(); 
    
          const isUnblock = form.action.includes('/unblock');
    
          Swal.fire({
            title: isUnblock ? 'Unblock User?' : 'Block User?',
            text: isUnblock 
              ? "This will allow the user access again." 
              : "This will restrict the user from accessing the system.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: isUnblock ? '#16a34a' : '#dc2626',
            cancelButtonColor: '#6b7280',
            confirmButtonText: isUnblock ? 'Yes, Unblock' : 'Yes, Block'
          }).then((result) => {
            if (result.isConfirmed) {
              form.submit(); 
            }
          });
        });
      });


    </script>
  
</body>
</html>
