<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Offers</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-slate-50" style="font-family:'Open Sans', sans-serif;">

    <%- include('../partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('../partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
              <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">Offer Management</h1>
              <p class="text-sm text-slate-500 mt-2">Configure product and category level promotional offers.</p>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
                <!-- Card 1 -->
                <a href="/admin/offers/product" 
                   class="group block bg-white border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition">
                  <img src="/images/36680.jpg" 
                       alt="Product Offers" 
                       class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-300">
                  <div class="p-4">
                    <h2 class="text-lg font-semibold text-gray-800">Product Offers</h2>
                    <p class="text-sm text-gray-500">Manage discounts applied to specific products.</p>
                  </div>
                </a>
            
                <!-- Card 2 -->
                <a href="/admin/offers/category" 
                   class="group block bg-white border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition">
                  <img src="/images/18038.jpg" 
                       alt="Category Offers" 
                       class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-300">
                  <div class="p-4">
                    <h2 class="text-lg font-semibold text-gray-800">Category Offers</h2>
                    <p class="text-sm text-gray-500">Create and manage offers for whole categories.</p>
                  </div>
                </a>

        </main>

    </div>

    <script>
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('sidebar');

        menuBtn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        })
    </script>
    
    

</body>
</html>
            
