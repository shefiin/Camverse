<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Edit Category</title>
    <script>
        tailwind.config = {
          theme: {
            extend: {
              screens: {
                xl1180: '1170px',
              }
            }
          }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body class="bg-slate-50" style="font-family: 'Kanit', sans-serif;">
    
    <%- include('partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full relative">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
              <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">Edit Category</h1>
              <p class="text-sm text-slate-500 mt-2">Update category details, status, and image.</p>
            </div>
                        
                <form action="/admin/categories/edit/<%= category._id %>?_method=PATCH" method="POST" enctype="multipart/form-data" class="space-y-6">

                    <div class="grid grid-cols-1 xl1180:grid-cols-12 gap-6 border border-slate-200 bg-white p-4 md:p-6 shadow-sm">
                      
                        <div class="xl1180:col-span-3 border border-slate-200 bg-slate-50 p-4">
                            <div class="flex flex-col items-center">
                                <div class="flex flex-col items-center w-56 md:w-60">
                                    <label class="block text-slate-700 font-semibold mb-2">Category Image</label>
                                    <p class="mb-3 inline-flex items-center gap-2 border border-slate-300 bg-white px-2.5 py-1 text-[11px] tracking-wide text-slate-600">
                                      <i class="fa-regular fa-image text-slate-500"></i>
                                      JPG, PNG, WEBP • 1 image
                                    </p>
                                  
                                   
                                    <div id="imageContainer" class="relative border-2 border-dashed border-slate-300 aspect-square w-full max-w-[240px] bg-white flex items-center justify-center overflow-hidden">
                                        <input type="file" id="images" name="image" class="hidden" accept="image/*" />
                                      
                                        <% if (category.image) { %>
                                          <div id="previewContainer" class="absolute inset-0 w-full h-full">
                                            <img id="previewImage" src="<%= category.image[0].url %>" class="w-full h-full object-contain bg-white" />
                                            <button id="removePreviewBtn" type="button" class="absolute top-2 right-2 bg-white text-gray-700 hover:text-red-600 w-7 h-7 flex items-center justify-center shadow active:scale-[0.95] transition duration-150 ease-out transform">
                                              <i class="fa-solid fa-xmark"></i>
                                            </button>
                                          </div>
                                        <% } else { %>
                                          <div id="previewContainer" class="absolute inset-0 urlw-full h-full hidden">
                                            <img id="previewImage" class="w-full h-full object-contain bg-white" />
                                            <button id="removePreviewBtn" type="button" class="absolute top-2 right-2 bg-white text-gray-700 hover:text-red-600 w-7 h-7 flex items-center justify-center shadow active:scale-[0.95] transition duration-150 ease-out transform">
                                              <i class="fa-solid fa-xmark"></i>
                                            </button>
                                          </div>
                                        <% } %>
                                      </div>
                                      
                                                                     
                                    <div id="thumbnailContainer" class="flex gap-2 mt-2 overflow-x-auto w-full justify-start"></div>

                                    <p class="text-sm text-red-600 hidden my-2" id="imageError"></p>
                                                                     
                                    <label for="images" class="mt-3 inline-flex items-center gap-2 bg-slate-800 hover:bg-black text-white font-medium px-3 py-2 cursor-pointer transition">
                                      <i class="fa-solid fa-cloud-arrow-up text-base"></i>
                                      Upload Image
                                    </label>
                                  </div>
                                  
                            </div>
                        </div>

                        
                        <div class="xl1180:col-span-9 border border-slate-200 bg-white p-4 md:p-5 grid grid-cols-1 gap-6 text-left">
                            <h2 class="text-sm font-semibold text-slate-700">Category Details</h2>
                                                       
                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="name">Category Name</label>
                                <input type="text" name="name" id="name" required
                                    value="<%= category.name %>"
                                    class="w-full border border-slate-300 px-4 py-2.5 text-left focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                    <span id="nameError" class="text-red-500 text-sm hidden">Name too long (max 25 characters)</span>    
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="status">Status</label>
                                <select name="status" id="status" required
                                    class="w-full h-[44px] border border-slate-300 px-4 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="Active" <%= category.status === 'Active' ? 'selected' : '' %>>Active</option>
                                    <option value="Inactive" <%= category.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
                                </select>                              
                            </div>
                                                                                        
                            <div class="md:col-span-2">
                                <label class="block text-gray-700 font-medium mb-2" for="description">Description</label>
                                <textarea name="description" id="description" rows="5" required                                    
                                    class="w-full border border-slate-300 px-4 py-2.5 text-left focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <%= category.description %>
                                </textarea>
                                <span id="descError" class="text-red-500 text-sm hidden">Description too long (max 100 characters)</span>
                            </div>
                        </div>

                        <div class="pt-6 flex justify-end">
                            <button type="submit"
                                id="addProductBtn"
                                class="bg-green-600 hover:bg-green-700 text-white px-7 py-2.5 font-medium shadow active:scale-[0.95] transition duration-150 ease-out transform">
                                Save Changes
                            </button>
                        </div>
                        
                    </div>
                </form>
        </main>
    </div>

    <script src="/js/admin/add-categories.js"></script>
    
</body>
</html>
