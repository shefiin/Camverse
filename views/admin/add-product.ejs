<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Product Management</title>
    <script>
        tailwind.config = {
          theme: {
            extend: {
              screens: {
                xl1180: '1170px',
              }
            }
          }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body class="bg-slate-50" style="font-family: 'Kanit', sans-serif;">
    
    <%- include('partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full relative">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
                <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">Add Product</h1>
                <p class="text-sm text-slate-500 mt-2">Create a new catalog product with images, pricing, and stock details.</p>
            </div>

            <div id="successMessage" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
                <div class="bg-white p-10 shadow-lg w-full max-w-md">
                  <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
                  <div class="w-full flex items-center justify-center py-4 px-4 text-6xl text-green-600">
                    <i class="fa-regular fa-circle-check"></i>
                  </div>
                  <h1 class="flex items-center justify-center text-2xl font-extralight mb-2" style="font-family: 'Kanit', sans-serif;">Product added successfully</h1>
                </div>
            </div>

            <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="space-y-6">
                <div class="grid grid-cols-1 xl1180:grid-cols-12 gap-6 border border-slate-200 bg-white p-4 md:p-6 shadow-sm">
                    <div class="xl1180:col-span-4 border border-slate-200 bg-slate-50 p-4">
                        <h2 class="text-sm font-semibold text-slate-700 mb-3">Product Images</h2>
                        <p class="text-xs text-slate-500 mb-4">Upload up to 10 images (`.jpeg`, `.png`, `.webp`).</p>

                        <div class="flex flex-col items-center">
                            <div class="flex flex-col items-center w-56 md:w-60">
                                <div id="imageContainer" class="relative border-2 border-dashed border-slate-300 aspect-square w-full max-w-[240px] bg-white flex items-center justify-center overflow-hidden">
                                    <input type="file" id="images" name="images" required class="hidden" accept="image/*" multiple />
                                    <i class="fa-solid fa-image text-slate-300 text-4xl z-0"></i>

                                    <div id="previewContainer" class="absolute inset-0 w-full h-full hidden">
                                        <img id="previewImage" class="w-full h-full object-contain bg-white" />
                                        <button id="removePreviewBtn" type="button" class="absolute top-2 right-2 bg-white text-gray-700 hover:text-red-600 w-7 h-7 flex items-center justify-center shadow active:scale-[0.95] transition duration-150 ease-out transform">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </div>
                                </div>

                                <div id="thumbnailContainer" class="flex gap-2 mt-3 overflow-x-auto w-full justify-start"></div>
                                <p class="text-sm text-red-600 hidden my-2" id="imageError"></p>

                                <label for="images" class="mt-3 inline-flex items-center gap-2 bg-slate-800 hover:bg-black text-white font-medium px-3 py-2 cursor-pointer transition">
                                    <i class="fa-solid fa-cloud-arrow-up text-base"></i>
                                    Upload Images
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="xl1180:col-span-8 border border-slate-200 bg-white p-4 md:p-5">
                        <h2 class="text-sm font-semibold text-slate-700 mb-4">Product Details</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="md:col-span-2">
                                <label class="block text-gray-700 font-medium mb-2" for="name">Product Name</label>
                                <input type="text" name="name" id="name" required
                                    class="w-full border border-slate-300 bg-white px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <span id="nameError" class="text-red-500 text-sm hidden">Name too long (max 100 characters)</span>
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="brand">Brand</label>
                                <select name="brand" id="brand" required
                                    class="w-full h-[44px] border border-slate-300 px-4 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="" disabled selected>Select Brand</option>
                                    <% brands.forEach(brand => { %>
                                        <option value="<%= brand._id %>"><%= brand.name %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="category">Category</label>
                                <select name="category" id="category" required
                                    class="w-full h-[44px] border border-slate-300 px-4 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="" disabled selected>Select Category</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category._id %>"><%= category.name %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="price">Price (₹)</label>
                                <input type="number" name="price" id="price" min="0" step="0.01" required
                                    class="w-full border border-slate-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <span id="priceError" class="text-red-500 text-sm hidden">Price must be positive</span>
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="mrp">MRP (₹)</label>
                                <input type="number" name="mrp" id="mrp" min="0" step="0.01" required
                                    class="w-full border border-slate-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <span id="mrpError" class="text-red-500 text-sm hidden">MRP must be positive and greater than price</span>
                            </div>

                            <div>
                                <label class="block text-gray-700 font-medium mb-2" for="stock">Stock Count</label>
                                <input type="number" name="stock" id="stock" min="0" required
                                    class="w-full border border-slate-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                                <span id="stockError" class="text-red-500 text-sm hidden">Stock must not be negative</span>
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-gray-700 font-medium mb-2" for="description">Description</label>
                                <textarea name="description" id="description" rows="6" required
                                    class="w-full border border-slate-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                                <span id="descError" class="text-red-500 text-sm hidden">Description too long (max 500 characters)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end">
                    <button type="submit"
                        id="addProductBtn"
                        class="bg-green-600 hover:bg-green-700 text-white px-7 py-2.5 font-medium shadow active:scale-[0.95] transition duration-150 ease-out transform">
                        Add Product
                    </button>
                </div>
            </form>
        </main>
    </div>

    <script src="/js/admin/add-product.js"></script>
    <script>

        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get('success');

        if (success === '1') {
        const message = document.getElementById('successMessage');
        message.classList.remove('hidden');

        setTimeout(() => {
        message.classList.add('hidden');
        const newUrl = window.location.pathname;
        window.history.replaceState({}, document.title, newUrl);
        }, 2000); 

    }
    </script>

</body>
</html>
