<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Coupon Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .coupon {
            background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
            position: relative;
            overflow: hidden;
            border: 1px solid #94a3b8;
        }
        .coupon::before,
        .coupon::after {
            content: '';
            position: absolute;
            width: 24px;
            height: 24px;
            background: #0f172a;
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
        }
        .coupon::before {
            left: -12px;
        }
        .coupon::after {
            right: -12px;
        }
        .dashed-border {
            border: 2px dashed #64748b;
        }
    </style>
</head>
<body class="bg-slate-50" style="font-family:'Open Sans', sans-serif;">

    <%- include('../partials/adminNavbar') %>

    <div class="flex pt-[80px] min-h-screen">
        <%- include('../partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
              <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">Coupon Management</h1>
              <p class="text-sm text-slate-500 mt-2">Create, edit, and manage coupon visibility with clear status tracking.</p>
            </div>
            <% if (couponError) { %>
              <div class="mb-6 border-l-4 border-red-500 border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                <%= couponError %>
              </div>
            <% } %>


            <div class="flex justify-end">
              <button  
                  id="open-coupon-modal"
                  class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 shadow-sm flex items-center gap-2 active:scale-[0.95] transition duration-150 ease-out transform">
                  <i class="fa-solid fa-plus"></i>
                  ADD COUPON
              </button>
            </div>
          

            <div class="bg-slate-900 shadow p-4 md:p-5 mt-6 border border-slate-700">
                <div class="flex items-center justify-between mb-4">
                  <h2 class="text-white text-lg font-semibold">Coupons</h2>
                  <p class="text-xs text-slate-300">Total: <%= coupons.length %></p>
                </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-left text-sm text-gray-100">
                            <thead class="bg-slate-800 text-slate-100 text-sm md:text-base">
                                <tr>
                                    <th class="px-4 py-3">No.</th>
                                    <th class="px-4 py-3">Coupon</th>
                                    <th class="px-4 py-3">Description</th>
                                    <th class="px-4 py-3 text-center">Type</th>
                                    <th class="px-4 py-3 text-center">Min Purchase</th>
                                    <th class="px-4 py-3 text-center">From</th>
                                    <th class="px-4 py-3 text-center">To</th>
                                    <th class="px-4 py-3 text-center">Status</th>
                                    <th class="px-4 py-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-700">
                                <% if (!coupons.length) { %>
                                  <tr>
                                    <td colspan="9" class="px-4 py-10 text-center text-slate-400">No coupons found.</td>
                                  </tr>
                                <% } %>
                                <% coupons.forEach((coupon, index) => { %>
                                  <%
                                    const isExpired = coupon.endDate && new Date(coupon.endDate) < new Date();
                                    const displayStatus = coupon.isDeleted
                                      ? 'DELETED'
                                      : ((isExpired || coupon.status === 'INACTIVE') ? 'INACTIVE' : 'ACTIVE');
                                  %>
                                  <tr class="hover:bg-slate-800/80 divide-x divide-slate-700">
                                    <td class="px-4 py-2"><%= skip + index + 1 %></td>
                                    <td class="px-4 py-2">
                                      <button 
                                        class="coupon-btn active:scale-[0.95] transition duration-150 ease-out transform"
                                        data-id="<%= coupon._id %>"
                                        data-name="<%= coupon.name %>"
                                        data-description="<%= coupon.description %>"
                                        data-discount-type="<%= coupon.discountType %>"
                                        data-discount-value="<%= coupon.discountValue %>"
                                        data-min-purchase="<%= coupon.minPurchase || 0 %>"
                                        data-start-date="<%= coupon.startDate ? new Date(coupon.startDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>"
                                        data-end-date="<%= coupon.endDate ? new Date(coupon.endDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>"
                                        data-status="<%= displayStatus %>"
                                        data-usage-limit="<%= coupon.usageLimit || 0 %>"
                                        data-per-user-limit="<%= coupon.perUserLimit || 0 %>">
                                          <div class="coupon max-w-[250px] p-2 shadow-md text-slate-700 text-center">
                                            <div class="dashed-border p-2 border-2 border-dashed border-gray-400">
                                              <p class="text-base md:text-lg lg:text-xl">
                                                <span class="font-mono font-bold"><%= coupon.name %></span>
                                              </p>
                                            </div>
                                          </div>
                                      </button>
                                    </td>
                                    <td class="px-4 py-2 max-w-[220px] truncate text-slate-200"> <%= coupon.description %> </td>
                                    <td class="px-4 py-2 text-center font-medium"> <%= coupon.discountType %> </td>
                                    <td class="px-4 py-2 text-center">₹<%= (coupon.minPurchase || 0).toLocaleString('en-IN') %></td>
                                    <td class="px-4 py-2 text-center">
                                      <%= coupon.startDate ? new Date(coupon.startDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                                    </td>
                                    <td class="px-4 py-2 text-center">
                                      <%= coupon.endDate ? new Date(coupon.endDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                                    </td>
                                    <td class="px-4 py-2 text-center">
                                      <% if (displayStatus === 'ACTIVE') { %>
                                        <span class="inline-flex items-center rounded-full bg-green-600/20 px-3 py-1 text-xs text-green-300">ACTIVE</span>
                                      <% } else if (displayStatus === 'DELETED') { %>
                                        <span class="inline-flex items-center rounded-full bg-rose-600/20 px-3 py-1 text-xs text-rose-300">DELETED</span>
                                      <% } else { %>
                                        <span class="inline-flex items-center rounded-full bg-orange-600/20 px-3 py-1 text-xs text-orange-300">INACTIVE</span>
                                      <% } %>
                                    </td>
                                    <td class="px-4 py-3">      
                                      <div class="flex flex-col items-center gap-2">
                                        <% if (coupon.isDeleted) { %>
                                          <form action="/admin/coupons/restore/<%= coupon._id %>?_method=PATCH" method="POST">
                                            <button
                                              type="submit"
                                              class="w-24 text-xs py-1 bg-emerald-600 text-white hover:bg-emerald-700 active:scale-[0.95] transition duration-150 ease-out transform"
                                              title="Restore">
                                              Restore
                                            </button>
                                          </form>
                                        <% } else { %>
                                          <button 
                                            class="edit-coupon-btn w-24 text-white bg-blue-500 px-2 py-1 text-xs hover:bg-blue-600 active:scale-[0.95] transition duration-150 ease-out transform"
                                            data-id="<%= coupon._id %>"
                                            data-name="<%= coupon.name %>"
                                            data-description="<%= coupon.description %>"
                                            data-discount-type="<%= coupon.discountType %>"
                                            data-discount-value="<%= coupon.discountValue %>"
                                            data-min-purchase="<%= coupon.minPurchase || 0 %>"
                                            data-start-date="<%= coupon.startDate ? coupon.startDate.toISOString().split('T')[0] : '' %>"
                                            data-end-date="<%= coupon.endDate ? coupon.endDate.toISOString().split('T')[0] : '' %>">
                                            Edit
                                          </button>
                                          <form action="/admin/coupons/delete/<%= coupon._id %>?_method=PATCH" method="POST" class="coupon-delete-form">
                                            <button
                                              type="button"
                                              class="w-24 text-xs py-1 bg-red-500 text-white hover:bg-red-600 open-delete-modal active:scale-[0.95] transition duration-150 ease-out transform"
                                              title="Delete">
                                              Delete
                                            </button>
                                          </form>
                                        <% } %>
                                      </div>
                                    </td>
                                  </tr>
                                <% }); %>
                            </tbody>
                                                         
                        </table>
                    </div>
            </div>
              
              <%- include('../partials/pagination') %>              

        </main>
        <%- include('addCoupon') %>

        <div id="coupon-mod"
             class="fixed inset-0 bg-black bg-opacity-60 z-50 opacity-0 pointer-events-none transition-opacity duration-300">
          <div id="coupon-det"
               class="bg-white shadow-lg p-6 w-full max-w-lg mx-auto mt-24 transform scale-90 opacity-0 transition-all duration-300">
            <h2 class="text-xl font-semibold mb-4 text-gray-800">Coupon Details</h2>
            <div class="space-y-2 text-sm text-gray-700">
              <p><span class="font-semibold">Name:</span> <span id="detail-name">-</span></p>
              <p><span class="font-semibold">Description:</span> <span id="detail-description">-</span></p>
              <p><span class="font-semibold">Type:</span> <span id="detail-discount-type">-</span></p>
              <p><span class="font-semibold">Discount Value:</span> <span id="detail-discount-value">-</span></p>
              <p><span class="font-semibold">Min Purchase:</span> <span id="detail-min-purchase">-</span></p>
              <p><span class="font-semibold">Start Date:</span> <span id="detail-start-date">-</span></p>
              <p><span class="font-semibold">End Date:</span> <span id="detail-end-date">-</span></p>
              <p><span class="font-semibold">Status:</span> <span id="detail-status">-</span></p>
              <p><span class="font-semibold">Usage Limit:</span> <span id="detail-usage-limit">-</span></p>
              <p><span class="font-semibold">Per User Limit:</span> <span id="detail-per-user-limit">-</span></p>
            </div>
            <div class="mt-6 flex justify-end">
              <button id="close-coupon-details"
                      class="px-4 py-2 bg-gray-200 hover:bg-gray-300 active:scale-[0.95] transition duration-150 ease-out transform">
                Close
              </button>
            </div>
          </div>
        </div>

        <div id="deletePermission" 
             class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
          <div class="bg-white p-10 shadow-lg w-full max-w-md">
            <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
            <div class="w-full flex items-center justify-center py-4 px-4 text-7xl text-gray-300">
              <i class="fa-solid fa-circle-exclamation"></i>
            </div>
            <p class="text-lg font-extralight mb-6 text-center" style="font-family: 'Kanit', sans-serif;">
              Are you sure you want to delete this coupon?
            </p>
            <div class="flex items-center justify-center space-x-4 mt-4">
              <button id="confirmDelete" class="bg-red-600 w-full text-white px-12 py-2 hover:bg-red-700 transition duration-200 ease-in-out active:scale-[0.95] transition duration-150 ease-out transform">
                Confirm
              </button>
              <button id="cancelDelete" class="bg-blue-500 w-full text-white px-12 py-2 hover:bg-blue-600 transition duration-200 ease-in-out active:scale-[0.95] transition duration-150 ease-out transform">
                Cancel
              </button>
            </div>
          </div>
        </div>
      


    </div>

    <script>
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('sidebar');
        const couponForm = document.getElementById("coupon-form");
        const modalTitle = document.getElementById("modal-title");
        const couponSubmitBtn = document.getElementById("coupon-submit-btn");
        const couponNameInput = document.getElementById("couponName");
        const couponDescriptionInput = document.getElementById("couponDescription");
        const couponDiscountValueInput = document.getElementById("couponDiscountValue");
        const couponMinPurchaseInput = document.getElementById("couponMinPurchase");
        const couponStartDateInput = document.getElementById("couponStartDate");
        const couponEndDateInput = document.getElementById("couponEndDate");

        menuBtn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        })


        document.querySelectorAll(".coupon-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                const closeBtn = document.getElementById("close-coupon-details");
                const modal = document.getElementById("coupon-mod");
                const card = document.getElementById("coupon-det");
                const detailName = document.getElementById("detail-name");
                const detailDescription = document.getElementById("detail-description");
                const detailDiscountType = document.getElementById("detail-discount-type");
                const detailDiscountValue = document.getElementById("detail-discount-value");
                const detailMinPurchase = document.getElementById("detail-min-purchase");
                const detailStartDate = document.getElementById("detail-start-date");
                const detailEndDate = document.getElementById("detail-end-date");
                const detailStatus = document.getElementById("detail-status");
                const detailUsageLimit = document.getElementById("detail-usage-limit");
                const detailPerUserLimit = document.getElementById("detail-per-user-limit");

                if (detailName) detailName.textContent = btn.dataset.name || "-";
                if (detailDescription) detailDescription.textContent = btn.dataset.description || "-";
                if (detailDiscountType) detailDiscountType.textContent = btn.dataset.discountType || "-";
                if (detailDiscountValue) {
                  detailDiscountValue.textContent =
                    (btn.dataset.discountType === "PERCENTAGE")
                      ? `${btn.dataset.discountValue || 0}%`
                      : `₹${Number(btn.dataset.discountValue || 0).toLocaleString("en-IN")}`;
                }
                if (detailMinPurchase) detailMinPurchase.textContent = `₹${Number(btn.dataset.minPurchase || 0).toLocaleString("en-IN")}`;
                if (detailStartDate) detailStartDate.textContent = btn.dataset.startDate || "-";
                if (detailEndDate) detailEndDate.textContent = btn.dataset.endDate || "-";
                if (detailStatus) detailStatus.textContent = btn.dataset.status || "-";
                if (detailUsageLimit) detailUsageLimit.textContent = btn.dataset.usageLimit || "0";
                if (detailPerUserLimit) detailPerUserLimit.textContent = btn.dataset.perUserLimit || "0";

                // open modal
                modal.classList.remove("opacity-0", "pointer-events-none");
                card.classList.remove("scale-90", "opacity-0");
                card.classList.add("scale-100", "opacity-100");

                // close modal (button)
                closeBtn.addEventListener("click", () => {
                modal.classList.add("opacity-0", "pointer-events-none");
                card.classList.add("scale-90", "opacity-0");
                card.classList.remove("scale-100", "opacity-100");
                });

                // close modal (background click)
                modal.addEventListener("click", (e) => {
                if (e.target === modal) {
                    modal.classList.add("opacity-0", "pointer-events-none");
                    card.classList.add("scale-90", "opacity-0");
                    card.classList.remove("scale-100", "opacity-100");
                }
                });
            });
        });

        document.querySelectorAll(".edit-coupon-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const id = btn.dataset.id;
            if (!id || !couponForm) return;

            couponForm.action = `/admin/coupons/edit/${id}?_method=PATCH`;
            if (modalTitle) modalTitle.textContent = "Edit Coupon";
            if (couponSubmitBtn) couponSubmitBtn.textContent = "Save Changes";
            if (couponNameInput) couponNameInput.value = btn.dataset.name || "";
            if (couponDescriptionInput) couponDescriptionInput.value = btn.dataset.description || "";
            if (couponDiscountValueInput) couponDiscountValueInput.value = btn.dataset.discountValue || "";
            if (couponMinPurchaseInput) couponMinPurchaseInput.value = btn.dataset.minPurchase || "0";
            if (couponStartDateInput) couponStartDateInput.value = btn.dataset.startDate || "";
            if (couponEndDateInput) couponEndDateInput.value = btn.dataset.endDate || "";

            const selectedType = btn.dataset.discountType || "";
            const typeRadio = couponForm.querySelector(`input[name="discountType"][value="${selectedType}"]`);
            if (typeRadio) typeRadio.checked = true;

            if (typeof window.openCouponModal === "function") {
              window.openCouponModal();
            }
          });
        });

        const deleteModal = document.getElementById("deletePermission");
        const confirmDeleteBtn = document.getElementById("confirmDelete");
        const cancelDeleteBtn = document.getElementById("cancelDelete");
        let selectedDeleteForm = null;

        document.querySelectorAll(".open-delete-modal").forEach((btn) => {
          btn.addEventListener("click", () => {
            selectedDeleteForm = btn.closest("form");
            deleteModal.classList.remove("hidden");
          });
        });

        if (cancelDeleteBtn) {
          cancelDeleteBtn.addEventListener("click", () => {
            deleteModal.classList.add("hidden");
            selectedDeleteForm = null;
          });
        }

        if (confirmDeleteBtn) {
          confirmDeleteBtn.addEventListener("click", () => {
            if (selectedDeleteForm) {
              selectedDeleteForm.submit();
            }
          });
        }

        if (deleteModal) {
          deleteModal.addEventListener("click", (e) => {
            if (e.target === deleteModal) {
              deleteModal.classList.add("hidden");
              selectedDeleteForm = null;
            }
          });
        }

    </script>

</body>
</html>
