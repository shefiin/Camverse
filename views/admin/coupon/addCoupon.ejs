<div id="coupon-modal" 
    class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 opacity-0 pointer-events-none transition-opacity duration-300">
    <div id="coupon-card"
      class="bg-white shadow-lg p-6 max-h-[80vh] overflow-y-auto w-full max-w-3xl transform scale-90 opacity-0 transition-all duration-300">
      
      <h2 id="modal-title" class="text-xl font-semibold mb-6 text-gray-800">Add Coupon</h2>

      <form id="coupon-form" action="/admin/coupons/add" method="POST" class="space-y-6">
        <!-- Type -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Coupon Type</label>
          <div class="flex items-center gap-4">
            <label class="flex items-center gap-2">
              <input type="radio" name="discountType" value="PERCENTAGE" class="text-teal-600" required>
              <span>Percentage</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="discountType" value="FLAT" class="text-teal-600">
              <span>Flat Amount</span>
            </label>
          </div>
        </div>
        
        <!-- Coupon Name -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Coupon Name</label>
          <input 
            id="couponName"
            type="text" 
            name="couponName" 
            class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500 uppercase"
            style="text-transform: uppercase;"  
            placeholder="Enter coupon name" 
            required>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Coupon Description</label>
            <textarea 
              id="couponDescription"
              name="description" 
              rows="3"
              class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500 resize-none"
              placeholder="Enter a short description for the coupon (e.g. Flat ₹500 off on first order)"
              required></textarea>
        </div>
          
        <!-- Coupon Value -->
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Discount value</label>
            <input id="couponDiscountValue" type="number" name="discountValue" 
                   class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500" 
                   placeholder="Enter percentage or amount" required>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Minimum Purchase Amount</label>
            <input id="couponMinPurchase" type="number" name="minPurchase"
                   class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500"
                   placeholder="Enter minimum cart amount"
                   min="0"
                   value="0"
                   required>
        </div>
  
        <!-- Date Range -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">From</label>
            <input id="couponStartDate" type="date" name="startDate" 
                   class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">To</label>
            <input id="couponEndDate" type="date" name="endDate" 
                   class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500" required>
          </div>
        </div>
  
        <!-- Buttons -->
        <div class="flex justify-end gap-4 mt-6">
          <button type="button" 
                  id="close-coupon-modal"
                  class="px-4 py-2 bg-gray-200 hover:bg-gray-300 active:scale-[0.95] transition duration-150 ease-out transform">
              Cancel
          </button>
          <button id="coupon-submit-btn" type="submit"
                  class="px-4 py-2 bg-teal-600 text-white hover:bg-teal-700 active:scale-[0.95] transition duration-150 ease-out transform">Save Coupon</button>
        </div>
      </form>
    </div>
</div>



<script>
    (() => {
      const openBtn = document.getElementById("open-coupon-modal");
      const closeBtn = document.getElementById("close-coupon-modal");
      const modal = document.getElementById("coupon-modal");
      const card = document.getElementById("coupon-card");
      const couponForm = document.getElementById("coupon-form");
      const modalTitle = document.getElementById("modal-title");
      const submitBtn = document.getElementById("coupon-submit-btn");

      function openCouponModal() {
        modal.classList.remove("opacity-0", "pointer-events-none");
        card.classList.remove("scale-90", "opacity-0");
        card.classList.add("scale-100", "opacity-100");
      }

      function closeCouponModal() {
        modal.classList.add("opacity-0", "pointer-events-none");
        card.classList.add("scale-90", "opacity-0");
        card.classList.remove("scale-100", "opacity-100");
      }

      function setCouponAddMode() {
        couponForm.action = "/admin/coupons/add";
        modalTitle.textContent = "Add Coupon";
        submitBtn.textContent = "Save Coupon";
        couponForm.reset();
      }

      window.openCouponModal = openCouponModal;
      window.closeCouponModal = closeCouponModal;
      window.setCouponAddMode = setCouponAddMode;

      if (openBtn) {
        openBtn.addEventListener("click", () => {
          setCouponAddMode();
          openCouponModal();
        });
      }

      if (closeBtn) {
        closeBtn.addEventListener("click", () => {
          closeCouponModal();
        });
      }

      if (modal) {
        modal.addEventListener("click", (e) => {
          if (e.target === modal) {
            closeCouponModal();
          }
        });
      }
    })();
  </script>
  
