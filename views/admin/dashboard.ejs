<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body style="font-family:'Open Sans', sans-serif;">

    <%- include('partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 w-full">
            <h1 class="text-xl md:text-3xl font-semibold text-gray-800 mb-6">Admin Dashboard</h1>

            <div class="grid grid-col-1 md:grid-cols-2 custom:grid-cols-2 lg:grid-cols-4 gap-4">

                <div class="bg-black rounded-xl shadow p-3 flex flex-col items-center justify-center text-center">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-users text-blue-400"></i>
                        <h2 class="text-gray-400 text-md md:text-2xl font-medium">Total Users</h2>
                    </div>                    
                    <p class="font-light text-xl md:text-2xl text-white"><%= totalUsers %></p>
                </div>
                <div class="bg-black rounded-xl shadow p-3 flex flex-col items-center justify-center text-center">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-chart-line text-green-400"></i>
                        <h2 class="text-gray-400 text-md md:text-2xl font-medium">Items Sold</h2>
                    </div>                    
                    <p class="font-light text-xl md:text-2xl text-white"><%= productsSold %></p>
                </div>
                <div class="bg-black rounded-xl shadow p-3 flex flex-col items-center justify-center text-center">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-indian-rupee-sign text-yellow-400"></i>
                        <h2 class="text-gray-400 text-md md:text-2xl font-medium">Total Sales</h2>
                    </div>                    
                    <p class="font-light text-xl md:text-2xl text-white"><%= totalSales.toLocaleString() %></p>
                </div>
                <div class="bg-black rounded-xl shadow p-3 flex flex-col items-center justify-center text-center">
                    <div class="flex items-center space-x-2">
                        <i class="fa-solid fa-hourglass-half text-orange-400"></i>
                        <h2 class="text-gray-400 text-md md:text-2xl font-medium">Pending Orders</h2>
                    </div>                    
                    <p class="font-light text-xl md:text-2xl text-white"><%= pendingOrders %></p>
                </div>
            </div>

            <div class="bg-black rounded-xl p-4 mt-6">
                <h2 class="text-white text-lg font-semibold mb-4">Top Sold Products</h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-left text-sm text-gray-100">
                            <thead class="bg-gray-800 text-gray-100 text-sm md:text-base">
                                <tr>
                                    <th class="px-4 py-3">ID</th>
                                    <th class="px-4 py-3">Image</th>
                                    <th class="px-4 py-3">Product</th>
                                    <th class="px-4 py-3">Category</th>
                                    <th class="px-4 py-3">Price</th>
                                    <th class="px-4 py-3">Units Sold</th>
                                    <th class="px-4 py-3">Revenue</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-700">
                              <% topProductsWithRevenue.forEach((product, index) => { %>
                                <tr class="hover:bg-gray-800">
                                  <td class="px-4 py-2"><%= skip + index + 1 %></td>
                                  <td class="px-4 py-2">
                                    <% if (product.images && product.images.length > 0) { %>
                                      <img src="<%= product.images[0].url %>" 
                                           alt="<%= product.name %>" 
                                           class="w-14 h-14 p-1 object-contain rounded bg-white">
                                    <% } else { %>
                                      <img src="/images/placeholder.png" 
                                           alt="No image available" 
                                           class="w-16 h-16 object-contain rounded">
                                    <% } %>
                                  </td>
                                  <td class="px-4 py-2 max-w-[150px] truncate"><%= product.name %></td>
                                  <td class="px-4 py-2"><%= product.category ? product.category.name : 'N/A' %></td>
                                  <td class="px-4 py-2">₹<%= product.price.toLocaleString() %></td>
                                  <td class="px-4 py-2"><%= product.sold %></td>
                                  <td class="px-4 py-2">₹<%= product.revenue.toLocaleString() %></td>                                 
                              </tr>
                              <% }); %> 
                            </tbody>
                        </table>
                    </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
                <div class="bg-black rounded-xl p-4">
                    <h3 class="text-white text-base font-semibold mb-3">Most Selling Categories</h3>
                    <canvas id="categoryPieChart" height="220"></canvas>
                </div>
                <div class="bg-black rounded-xl p-4">
                    <h3 class="text-white text-base font-semibold mb-3">Most Selling Brands</h3>
                    <canvas id="brandPieChart" height="220"></canvas>
                </div>
                <div class="bg-black rounded-xl p-4 lg:col-span-2">
                    <h3 class="text-white text-base font-semibold mb-3">Sales by Month</h3>
                    <canvas id="monthLineChart" height="120"></canvas>
                </div>
                <div class="bg-black rounded-xl p-4">
                    <h3 class="text-white text-base font-semibold mb-3">Sales by Week</h3>
                    <canvas id="weekBarChart" height="180"></canvas>
                </div>
                <div class="bg-black rounded-xl p-4">
                    <h3 class="text-white text-base font-semibold mb-3">Sales by Year</h3>
                    <canvas id="yearBarChart" height="180"></canvas>
                </div>
            </div>
            <%-include('partials/pagination') %>
            
        </main>

    </div>

    <script>
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('sidebar');

        menuBtn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        const analytics = <%- JSON.stringify(analytics || {}) %>;
        const chartTextColor = "#d1d5db";

        const baseOptions = {
            responsive: true,
            plugins: {
                legend: {
                    labels: { color: chartTextColor }
                }
            },
            scales: {
                x: { ticks: { color: chartTextColor }, grid: { color: "rgba(255,255,255,0.08)" } },
                y: { ticks: { color: chartTextColor }, grid: { color: "rgba(255,255,255,0.08)" } }
            }
        };

        new Chart(document.getElementById("categoryPieChart"), {
            type: "pie",
            data: {
                labels: analytics.categories?.labels || [],
                datasets: [{
                    data: analytics.categories?.data || [],
                    backgroundColor: ["#14b8a6", "#3b82f6", "#f59e0b", "#f43f5e", "#22c55e", "#8b5cf6"],
                    borderColor: "transparent",
                    borderWidth: 0,
                    radius: "78%"
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        labels: {
                            color: chartTextColor,
                            usePointStyle: true,
                            pointStyle: "rect",
                            boxWidth: 10,
                            boxHeight: 10
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById("brandPieChart"), {
            type: "pie",
            data: {
                labels: analytics.brands?.labels || [],
                datasets: [{
                    data: analytics.brands?.data || [],
                    backgroundColor: ["#06b6d4", "#f97316", "#84cc16", "#eab308", "#ec4899", "#6366f1"],
                    borderColor: "transparent",
                    borderWidth: 0,
                    radius: "78%"
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        labels: {
                            color: chartTextColor,
                            usePointStyle: true,
                            pointStyle: "rect",
                            boxWidth: 10,
                            boxHeight: 10
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById("monthLineChart"), {
            type: "line",
            data: {
                labels: analytics.monthlySales?.labels || [],
                datasets: [{
                    label: "Revenue (₹)",
                    data: analytics.monthlySales?.data || [],
                    borderColor: "#14b8a6",
                    backgroundColor: "rgba(20,184,166,0.22)",
                    fill: true,
                    tension: 0.32
                }]
            },
            options: baseOptions
        });

        new Chart(document.getElementById("weekBarChart"), {
            type: "bar",
            data: {
                labels: analytics.weeklySales?.labels || [],
                datasets: [{
                    label: "Revenue (₹)",
                    data: analytics.weeklySales?.data || [],
                    backgroundColor: "#3b82f6"
                }]
            },
            options: baseOptions
        });

        new Chart(document.getElementById("yearBarChart"), {
            type: "bar",
            data: {
                labels: analytics.yearlySales?.labels || [],
                datasets: [{
                    label: "Revenue (₹)",
                    data: analytics.yearlySales?.data || [],
                    backgroundColor: "#f59e0b"
                }]
            },
            options: baseOptions
        });
    </script>
    
    

</body>
</html>
