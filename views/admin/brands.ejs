<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Brand Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<style>
  @keyframes modal-pop {
    0% {
      opacity: 0;
      transform: scale(0.95);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .animate-modal {
    animation: modal-pop 0.3s ease-out forwards;
  }
</style>

<body class="bg-slate-50" style="font-family: 'Kanit', sans-serif;">
    
    <%- include('partials/adminNavbar') %>

    <div class="flex pt-[80px]">
        <%- include('partials/adminSidebar') %>

        <main class="md:ml-56 flex-1 p-6 md:p-10 w-full relative">
            <div class="mb-8 border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Admin Panel</p>
              <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mt-2">Brand Management</h1>
              <p class="text-sm text-slate-500 mt-2">Maintain brand records and publishing status across the catalog.</p>
            </div>

            <div id="successMessage" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
                <div class="bg-white p-10 shadow-lg w-full max-w-md">
                  <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
                  <div class="w-full flex items-center justify-center py-4 px-4 text-6xl text-green-600">
                    <i class="fa-regular fa-circle-check"></i>
                  </div>
                  <h1 class="flex items-center justify-center text-2xl font-extralight mb-2" style="font-family: 'Kanit', sans-serif;">Brand updated successfully</h1>
                </div>
            </div>

            <div id="dltSuccess" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
                <div class="bg-white p-10 shadow-lg w-full max-w-md">
                  <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
                  <div class="w-full flex items-center justify-center py-4 px-4 text-6xl text-green-600">
                    <i class="fa-regular fa-circle-check"></i>
                  </div>
                  <h1 class="flex items-center justify-center text-2xl font-extralight mb-2" style="font-family: 'Kanit', sans-serif;">Brand deleted successfully</h1>
                </div>
            </div>

            <div id="restoreSuccess" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
              <div class="bg-white p-10 shadow-lg w-full max-w-md">
                <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
                <div class="w-full flex items-center justify-center py-4 px-4 text-6xl text-green-600">
                  <i class="fa-regular fa-circle-check"></i>
                </div>
                <h1 class="flex items-center justify-center text-2xl font-extralight mb-2" style="font-family: 'Kanit', sans-serif;">Brand restored successfully</h1>
              </div>
          </div>

          <div id="deletePermission" 
                class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-60 z-50 hidden">
            <div class="bg-white p-10 shadow-lg w-full max-w-md animate-modal">
              <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: Michroma, sans-serif;">Camverse</h2>
              <div class="w-full flex items-center justify-center py-4 px-4 text-7xl text-gray-300">
                <i class="fa-solid fa-circle-exclamation"></i>
              </div>
              <p class="text-lg font-extralight mb-6 text-center" style="font-family: 'Kanit', sans-serif;">
                Are you sure you want to delete this product?
              </p>
              <div class="flex items-center justify-center space-x-4 mt-4">
                <button id="confirmDelete" class="bg-red-600 w-full text-white px-12 py-2 hover:bg-red-700 transition duration-200 ease-in-out active:scale-[0.95] transition duration-150 ease-out transform">
                  Confirm
                </button>
                <button id="cancelDelete" class="bg-blue-500 w-full text-white px-12 py-2 hover:bg-blue-600 transition duration-200 ease-in-out active:scale-[0.95] transition duration-150 ease-out transform">
                  Cancel
                </button>
              </div>
            </div>
          </div>

            <div class="flex justify-between items-center mb-6 border border-slate-200 bg-white p-4 shadow-sm">

                <div class="flex items-center space-x-1">
                    <div class="relative w-64 md:w-96">
                        <form
                        action="/admin/brands"
                        method="GET"
                        class="relative flex items-center"
                      >
                        <input
                          type="text"
                          name="search"
                          value="<%= typeof search !== 'undefined' ? search : '' %>"
                          placeholder="Search brands..."
                          class="pl-3 py-2 border border-gray-300 px-4 w-64 md:w-96 focus:outline-none focus:ring focus:border-none focus:ring-blue-200"
                        >
                    
                        <button
                          type="submit"
                          class="absolute inset-y-0 right-0 m-1 p-3 flex items-center bg-gray-200 text-gray-600 hover:text-blue-600 active:scale-[0.95] transition duration-150 ease-out transform">
                          <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    
                      </form>
                    </div>
                    <% if (search) { %>
                        <a
                          href="/admin/brands"
                          class="text-sm text-gray-500 hover:text-gray-600 bg-gray-200 hover:bg-gray-300 px-1 py-3"
                          title="Clear Search"
                        >
                          Clear
                        </a>
                      <% } %>
                </div>

                <a href="/admin/brands/add" 
                    class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 shadow transition duration-150 ease-out transform active:scale-[0.95]">
                    <i class="fa-solid fa-plus"></i>
                    Add Brand
                </a>
            </div>

            <div class="bg-slate-900 border border-slate-700 shadow p-4 md:p-5 mt-6">
                <h2 class="text-white text-lg font-semibold mb-4">Brands</h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-left text-sm text-gray-100">
                            <thead class="bg-slate-800 text-slate-100 text-sm md:text-base">
                                <tr>
                                    <th class="px-4 py-3">NO</th>
                                    <th class="px-4 py-3">Image</th>
                                    <th class="px-4 py-3">Brand</th>                                  
                                    <th class="px-4 py-3">Status</th>
                                    <th class="px-4 py-3">Last Updated</th>
                                    <th class="px-4 py-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-700">
                                <% if (brands.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="px-4 py-4 text-center text-gray-400">No categories found.</td>
                                    </tr>
                                <% } else { %>
                                    <% brands.forEach((brand, index) => { %>
                                        <tr>
                                            <td class="px-4 py-3"><%= (currentPage - 1) * 5 + index + 1 %></td>
                                            <td class="px-4 py-2">
                                              <% if (brand.image && brand.image.length > 0) { %>
                                                <img src="<%= brand.image[0].url %>" 
                                                     alt="<%= brand.name %>" 
                                                     class="w-20 h-20 object-contain">
                                              <% } else { %>
                                                <img src="/images/placeholder.png" 
                                                     alt="No image available" 
                                                     class="w-16 h-16 object-contain">
                                              <% } %>
                                            </td>
                                            <td class="px-4 py-3"><%= brand.name %></td>
                                            <td class="px-4 py-3">
                                              <% if(brand.isDeleted) { %>
                                                <span class="px-4 py-1 rounded-full text-red-400 bg-red-900/40 text-sm">Deleted</span>
                                              <% } else if (brand.status === 'Active') { %>
                                                  <span class="px-4 py-1 rounded-full text-green-400 bg-green-900/40 text-sm">Active</span>
                                              <% } else { %>
                                                  <span class="px-4 py-1 rounded-full text-gray-300 bg-gray-700/40 text-sm">Inactive</span>
                                              <% } %>
                                            </td>
                                            <td class="px-4 py-3"><%= brand.updatedAt?.toLocaleDateString() || 'N/A' %></td>
                                            <td class="px-4 py-3">

                                              <% if(brand.isDeleted) {%>
                                                <form action="/admin/brands/restore/<%= brand._id %>?_method=PATCH" method="POST" class="inline block-form">
                                                  <button type="submit" class="w-24 px-3 py-1 bg-green-600 text-white hover:bg-green-700 active:scale-[0.95] transition duration-150 ease-out transform">
                                                    Restore
                                                  </button>
                                                </form>
                                              <% } else { %>       
                                                <div class="flex flex-col items-start gap-2">
                                                  <a href="/admin/brands/edit/<%= brand._id %>" class="w-24 px-3 py-1 text-center bg-blue-600 text-white hover:bg-blue-700 active:scale-[0.95] transition duration-150 ease-out transform" title="Edit">
                                                    Edit
                                                  </a>
                                                  <button 
                                                      type="button"
                                                      class="w-24 px-3 py-1 text-center bg-red-600 text-white hover:bg-red-700 deleteBtn active:scale-[0.95] transition duration-150 ease-out transform"
                                                      data-id="<%= brand._id %>"
                                                      title="Delete">
                                                      Delete
                                                  </button>
                                                </div>
                                              <% } %>                    
                                            </td>                                              
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
            </div>
            <%-include('partials/pagination') %>
        </main>
    </div>

    <script>
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('sidebar');

        menuBtn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });


        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get('success');

        if (success === '1') {
            const message = document.getElementById('successMessage');
            message.classList.remove('hidden');

            setTimeout(() => {
            message.classList.add('hidden');
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
            }, 2000); 

        } else if (success === '2') {
            const dltSuccess = document.getElementById('dltSuccess');
            dltSuccess.classList.remove('hidden');

            setTimeout(() => {
            dltSuccess.classList.add('hidden');
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
            }, 2000); 

        } else if (success === '3') {
            const restoreSuccess = document.getElementById('restoreSuccess');
            restoreSuccess.classList.remove('hidden');

            setTimeout(() => {
            restoreSuccess.classList.add('hidden');
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
            }, 2000); 
        }

        const deleteButtons = document.querySelectorAll('.deleteBtn');
        const deleteModal = document.getElementById('deletePermission');
        const confirmBtn = document.getElementById('confirmDelete');
        const cancelBtn = document.getElementById('cancelDelete');
        const deletForm = document.getElementById('deleteForm');

        let currentDeleteId = null;

        deleteButtons.forEach((button) => {
            button.addEventListener('click', () => {
                currentDeleteId = button.getAttribute('data-id');
                deleteModal.classList.remove('hidden');
            });
        });

        confirmBtn.addEventListener('click', () => {
            if (currentDeleteId) {
                deleteForm.setAttribute('action', `/admin/brands/delete/${currentDeleteId}?_method=PATCH`);
                deleteForm.submit();
            }
        });
            
        cancelBtn.addEventListener('click', () => {
            deleteModal.classList.add('hidden');
            currentDeleteId = null;
        });  

    </script>

<form id="deleteForm" method="POST" style="display: none;"></form>

</body>
</html>
