<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title><%= title || "Camverse" %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="wallet-page min-h-screen flex flex-col" style="font-family:'Open Sans', sans-serif";>

    <%- include('../partials/userNavbar', { navbarTheme: 'light' }) %>

    <section class="flex-1 px-4 pt-12 pb-8 md:px-8 md:pt-[150px] md:pb-10 lg:px-16 mt-6 md:mt-8 mb-[280px]">
      <div class="max-w-6xl mx-auto">
        <h1 class="text-2xl md:text-3xl text-gray-800 text-center mb-10">My Wallet</h1>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-1">
            <div class="rounded-2xl bg-gradient-to-br from-emerald-600 to-teal-700 text-white p-6 shadow-lg">
              <div class="flex items-center justify-between">
                <p class="text-sm tracking-wide text-emerald-100">Available Balance</p>
                <i class="fa-solid fa-wallet text-xl"></i>
              </div>
              <p class="text-3xl font-semibold mt-4">₹<%= wallet ? Number(wallet.balance || 0).toLocaleString() : 0 %>.00</p>
              <p class="text-xs text-emerald-100 mt-2">Use balance for orders and get return refunds instantly.</p>
            </div>
            <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm mt-4">
              <p class="text-sm text-gray-500 mb-1">Total Transactions</p>
              <p class="text-2xl font-semibold text-gray-800"><%= wallet && wallet.transactions ? wallet.transactions.length : 0 %></p>
            </div>
          </div>

          <div class="lg:col-span-2 rounded-2xl border border-gray-200 bg-white shadow-sm p-4 md:p-6">
            <h2 class="text-lg md:text-xl font-semibold text-gray-800 mb-4">Transaction History</h2>

            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-5">
              <div class="flex flex-wrap items-center gap-2">
                <span class="text-sm text-gray-500 mr-1">Filter</span>
                <button type="button" onclick="filterTx('all', this)" class="filter-btn px-3 py-1.5 rounded-md border border-gray-300 bg-gray-900 text-white text-sm active:scale-[0.95] transition duration-150 ease-out transform">All</button>
                <button type="button" onclick="filterTx('CREDIT', this)" class="filter-btn px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-sm active:scale-[0.95] transition duration-150 ease-out transform">Credits</button>
                <button type="button" onclick="filterTx('DEBIT', this)" class="filter-btn px-3 py-1.5 rounded-md border border-gray-300 bg-white text-gray-700 text-sm active:scale-[0.95] transition duration-150 ease-out transform">Debits</button>
              </div>

              <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full md:w-auto">
                <input
                  id="searchBox"
                  type="text"
                  placeholder="Search transactions..."
                  onkeyup="searchTx()"
                  class="border border-gray-300 rounded-md px-3 py-2 text-sm w-full sm:w-64 focus:outline-none focus:ring-2 focus:ring-teal-200"
                >

                <select
                  id="sortSelect"
                  onchange="sortTx()"
                  class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-teal-200"
                >
                  <option value="newest">Newest First</option>
                  <option value="oldest">Oldest First</option>
                  <option value="high">High → Low</option>
                  <option value="low">Low → High</option>
                </select>
              </div>
            </div>

            <div id="transactions" class="space-y-3">
              <% if (wallet && wallet.transactions.length > 0) { %>
              <% wallet.transactions.forEach(tx => { %>
              <div
                class="tx-item rounded-xl border border-gray-200 bg-white px-4 py-3 hover:shadow-md transition flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
                data-type="<%= tx.type %>"
                data-desc="<%= (tx.description || '').toLowerCase() %>"
                data-amount="<%= tx.amount %>"
                data-date="<%= tx.createdAt %>"
              >
                <div>
                  <p class="text-gray-800 font-medium">
                    <%= tx.description || (tx.type === "CREDIT" ? "Amount Credited" : "Amount Debited") %>
                  </p>
                  <p class="text-xs text-gray-500 mt-1">
                    <%= new Date(tx.createdAt).toLocaleDateString("en-IN", { year: "numeric", month: "short", day: "numeric" }) %>
                    •
                    <%= new Date(tx.createdAt).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" }) %>
                  </p>
                  <% if (tx.orderId) { %>
                  <a href="/order/details/<%= tx.orderId %>" class="inline-block mt-1 text-sm text-teal-700 hover:underline">View Order</a>
                  <% } %>
                </div>

                <div class="text-right">
                  <p class="<%= tx.type === 'CREDIT' ? 'text-green-600' : 'text-red-600' %> text-lg font-semibold">
                    <%= tx.type === 'CREDIT' ? '+ ' : '- ' %>₹<%= tx.amount.toLocaleString() %>
                  </p>
                  <p class="text-xs text-gray-500"><%= tx.type %></p>
                </div>
              </div>
              <% }) %>
              <% } else { %>
              <div class="rounded-xl border border-dashed border-gray-300 bg-gray-50 p-8 text-center">
                <p class="text-gray-500">No transactions yet.</p>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>


    <%- include('../partials/userFooter') %>

    <script src="/js/user/homePage.js"></script>

    <script>
        function filterTx(type, btn) {
          document.querySelectorAll('.tx-item').forEach(item => {
            if (type === 'all' || item.dataset.type === type) {
              item.style.display = 'flex';
            } else {
              item.style.display = 'none';
            }
          });
        
          // highlight active filter
          document.querySelectorAll('.filter-btn').forEach(el => {
            el.classList.remove('bg-gray-900', 'text-white');
            el.classList.add('bg-white', 'text-gray-700');
          });
          if (btn) {
            btn.classList.remove('bg-white', 'text-gray-700');
            btn.classList.add('bg-gray-900', 'text-white');
          }
        }
        
        function searchTx() {
          const query = document.getElementById("searchBox").value.toLowerCase();
          document.querySelectorAll('.tx-item').forEach(item => {
            item.style.display = item.dataset.desc.includes(query) ? 'flex' : 'none';
          });
        }
        
        function sortTx() {
          const sortBy = document.getElementById("sortSelect").value;
          let items = Array.from(document.querySelectorAll('.tx-item'));
          const container = document.getElementById("transactions");
        
          items.sort((a, b) => {
            let amountA = parseFloat(a.dataset.amount);
            let amountB = parseFloat(b.dataset.amount);
            let dateA = new Date(a.dataset.date);
            let dateB = new Date(b.dataset.date);
        
            switch (sortBy) {
              case "newest": return dateB - dateA;
              case "oldest": return dateA - dateB;
              case "high": return amountB - amountA;
              case "low": return amountA - amountB;
            }
          });
        
          container.innerHTML = "";
          items.forEach(i => container.appendChild(i));
        }
        </script>

    <style>
      .wallet-page footer {
        padding-top: 1.5rem;
        padding-bottom: 1.5rem;
      }
      .wallet-page footer > div:last-child {
        margin-top: 1rem;
        padding-top: 0.75rem;
      }
    </style>
        

</body>
</html>        
