<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/fonts.css">
  <title><%= title || "Camverse" %></title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800" style="font-family:'Open Sans', sans-serif;">
  <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

  <section class="pt-28 pb-16 px-4 sm:px-6 lg:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-700 text-white p-8 sm:p-10 shadow-xl mb-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-300">Camverse Support</p>
        <h1 class="text-3xl sm:text-4xl font-semibold mt-2">Contact Us</h1>
        <p class="mt-3 text-sm sm:text-base text-gray-300 font-extralight">
          Have a question about an order, product, or refund? Send us a message.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">
          <h2 class="text-2xl font-semibold">Get in Touch</h2>

          <div class="space-y-4 text-sm sm:text-base text-gray-700 font-extralight">
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-location-dot mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Address</p>
                <p>123 Street, City, Country</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-phone mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Phone</p>
                <p>+91 9876543210</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-envelope mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <p>support@camverse.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 shadow-sm p-6 sm:p-8">
          <h2 class="text-2xl font-semibold mb-5">Send a Message</h2>
          <% if (contactStatus === 'success') { %>
            <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 text-sm">
              Message sent successfully. We will get back to you soon.
            </div>
          <% } %>
          <% if (contactStatus === 'error') { %>
            <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 text-sm">
              <%= contactError || 'Failed to send message. Please try again.' %>
            </div>
          <% } %>
          <form class="space-y-4" method="POST" action="/contact">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input id="name" name="name" type="text" required maxlength="50" class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
              <p id="nameError" class="mt-1 text-xs text-red-600 hidden"></p>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input id="email" name="email" type="email" required maxlength="100" class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
              <p id="emailError" class="mt-1 text-xs text-red-600 hidden"></p>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
              <input id="subject" name="subject" type="text" required maxlength="120" class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
              <p id="subjectError" class="mt-1 text-xs text-red-600 hidden"></p>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
              <textarea id="message" name="message" rows="5" required maxlength="1000" class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500"></textarea>
              <p id="messageError" class="mt-1 text-xs text-red-600 hidden"></p>
            </div>
            <button id="contactSubmitBtn" type="submit" disabled class="bg-teal-700 hover:bg-teal-800 disabled:bg-gray-400 disabled:cursor-not-allowed text-white px-5 py-2 active:scale-[0.95] transition duration-150 ease-out transform">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/userFooter') %>
  <script src="/js/user/homePage.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.querySelector('form[action="/contact"]');
      if (!form) return;

      const fields = {
        name: form.querySelector('#name'),
        email: form.querySelector('#email'),
        subject: form.querySelector('#subject'),
        message: form.querySelector('#message')
      };
      const errors = {
        name: form.querySelector('#nameError'),
        email: form.querySelector('#emailError'),
        subject: form.querySelector('#subjectError'),
        message: form.querySelector('#messageError')
      };
      const submitBtn = form.querySelector('#contactSubmitBtn');
      const touched = {
        name: false,
        email: false,
        subject: false,
        message: false
      };
      let submitAttempted = false;

      const rules = {
        name(value) {
          const v = value.trim();
          if (!v) return 'Name is required';
          if (v.length < 2 || v.length > 50) return 'Name must be 2-50 characters';
          if (!/^[A-Za-z .'-]+$/.test(v)) return 'Name can only contain letters and spaces';
          return '';
        },
        email(value) {
          const v = value.trim();
          if (!v) return 'Email is required';
          if (v.length > 100) return 'Email is too long';
          if (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(v)) return 'Enter a valid email';
          return '';
        },
        subject(value) {
          const v = value.trim();
          if (!v) return 'Subject is required';
          if (v.length < 5 || v.length > 120) return 'Subject must be 5-120 characters';
          return '';
        },
        message(value) {
          const v = value.trim();
          if (!v) return 'Message is required';
          if (v.length < 10 || v.length > 1000) return 'Message must be 10-1000 characters';
          return '';
        }
      };

      const getErrorText = (key) => {
        const input = fields[key];
        if (!input) return 'Invalid input';
        return rules[key](input.value);
      };

      const validateOne = (key, showError = false) => {
        const input = fields[key];
        const errorEl = errors[key];
        if (!input || !errorEl) return false;

        const errorText = getErrorText(key);
        if (errorText) {
          if (showError) {
            errorEl.textContent = errorText;
            errorEl.classList.remove('hidden');
            input.classList.add('border-red-400');
            input.classList.remove('border-gray-300');
          } else {
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
            input.classList.remove('border-red-400');
            input.classList.add('border-gray-300');
          }
          return false;
        }

        errorEl.textContent = '';
        errorEl.classList.add('hidden');
        input.classList.remove('border-red-400');
        input.classList.add('border-gray-300');
        return true;
      };

      const validateAll = () => {
        const ok =
          !getErrorText('name') &&
          !getErrorText('email') &&
          !getErrorText('subject') &&
          !getErrorText('message');
        submitBtn.disabled = !ok;
        return ok;
      };

      Object.keys(fields).forEach((key) => {
        fields[key].addEventListener('input', () => {
          validateOne(key, touched[key] || submitAttempted);
          validateAll();
        });
        fields[key].addEventListener('blur', () => {
          touched[key] = true;
          validateOne(key, true);
          validateAll();
        });
      });

      form.addEventListener('submit', (e) => {
        submitAttempted = true;
        let allValid = true;
        Object.keys(fields).forEach((key) => {
          const valid = validateOne(key, true);
          if (!valid) allValid = false;
        });
        if (!allValid) {
          e.preventDefault();
        }
        validateAll();
      });

      validateAll();
    });
  </script>
</body>
</html>
