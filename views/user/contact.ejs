<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/fonts.css">
  <title>Contact Us</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800" style="font-family:'Open Sans', sans-serif;">
  <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

  <section class="pt-28 pb-16 px-4 sm:px-6 lg:px-10">
    <div class="max-w-6xl mx-auto">
      <div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-700 text-white p-8 sm:p-10 shadow-xl mb-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-300">Camverse Support</p>
        <h1 class="text-3xl sm:text-4xl font-semibold mt-2">Contact Us</h1>
        <p class="mt-3 text-sm sm:text-base text-gray-300 font-extralight">
          Have a question about an order, product, or refund? Send us a message.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">
          <h2 class="text-2xl font-semibold">Get in Touch</h2>

          <div class="space-y-4 text-sm sm:text-base text-gray-700 font-extralight">
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-location-dot mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Address</p>
                <p>123 Street, City, Country</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-phone mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Phone</p>
                <p>+91 9876543210</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-envelope mt-1 text-teal-600"></i>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <p>support@camverse.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 shadow-sm p-6 sm:p-8">
          <h2 class="text-2xl font-semibold mb-5">Send a Message</h2>
          <form class="space-y-4" method="POST" action="#">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input id="name" name="name" type="text" required class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input id="email" name="email" type="email" required class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
              <input id="subject" name="subject" type="text" required class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500">
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-200 focus:border-teal-500"></textarea>
            </div>
            <button type="submit" class="bg-teal-700 hover:bg-teal-800 text-white px-5 py-2 active:scale-[0.95] transition duration-150 ease-out transform">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/userFooter') %>
  <script src="/js/user/homePage.js"></script>
</body>
</html>
