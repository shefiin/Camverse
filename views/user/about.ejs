<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/fonts.css">
  <title>About Camverse</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body style="font-family:'Open Sans', sans-serif;">

  <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

  <main class="mt-24 px-6 md:px-16 pb-16 max-w-6xl mx-auto">
    <section class="relative overflow-hidden bg-gradient-to-r from-slate-900 via-slate-800 to-teal-900 text-white p-8 md:p-14 text-center">
      <p class="text-sm uppercase tracking-[0.2em] text-teal-300 mb-3">About Us</p>
      <h1 class="text-3xl md:text-5xl font-semibold leading-tight mb-4">Camverse: Built for Camera Lovers</h1>
      <p class="max-w-3xl mx-auto text-gray-200 text-sm md:text-base font-extralight">
        Camverse is a camera-first ecommerce platform focused on helping creators, hobbyists, and professionals
        choose the right gear with confidence. From mirrorless and DSLR to action and instant cameras, we curate
        products from trusted brands and make discovery simple.
      </p>
    </section>

    <section class="grid md:grid-cols-3 gap-6 mt-10">
      <div class="bg-white border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-2">What We Sell</h2>
        <p class="text-gray-600 text-sm font-extralight">
          Cameras, accessories, and creator essentials across all major segments and price ranges.
        </p>
      </div>
      <div class="bg-white border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-2">Why Camverse</h2>
        <p class="text-gray-600 text-sm font-extralight">
          Honest pricing, curated catalog, and a smooth buying experience from browsing to checkout.
        </p>
      </div>
      <div class="bg-white border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-2">Our Goal</h2>
        <p class="text-gray-600 text-sm font-extralight">
          Make camera shopping faster, clearer, and more enjoyable for every creator.
        </p>
      </div>
    </section>

    <section class="mt-10 bg-white border border-gray-200 p-6 md:p-8 text-center">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Our Promise</h2>
      <ul class="space-y-3 text-gray-700 text-sm md:text-base font-extralight inline-block text-left">
        <li><i class="fa-solid fa-check text-teal-600 mr-2"></i>Curated products from reliable brands</li>
        <li><i class="fa-solid fa-check text-teal-600 mr-2"></i>Simple and transparent shopping flow</li>
        <li><i class="fa-solid fa-check text-teal-600 mr-2"></i>Creator-focused camera categories</li>
      </ul>
      <div class="mt-6">
        <a href="/shop" class="inline-block bg-teal-700 hover:bg-teal-800 text-white px-6 py-3 transition duration-150 ease-out transform active:scale-[0.95]">
          Explore Cameras
        </a>
      </div>
    </section>
  </main>

  <%- include('partials/userFooter') %>
  <script src="/js/user/homePage.js"></script>
</body>
</html>
