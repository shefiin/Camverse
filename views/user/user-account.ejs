<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title><%= title || "Camverse" %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800" style="font-family:'Open Sans', sans-serif;">

    <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

    <section class="px-4 sm:px-6 lg:px-10 pt-28 pb-16">
        <div class="mx-auto max-w-6xl">
            <div class="mb-10 bg-gradient-to-r from-gray-900 via-gray-800 to-gray-700 px-6 py-8 text-white shadow-xl sm:px-10">
                <p class="text-xs tracking-[0.25em] text-gray-300 uppercase">Camverse Account</p>
                <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">My Account</h1>
                <p class="mt-2 text-sm text-gray-300 sm:text-base">Manage profile, orders, addresses, wishlist, and wallet from one place.</p>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
                <a href="/user/profile/<%= user._id %>" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-teal-50 text-teal-700">
                        <i class="fa-solid fa-circle-user text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Profile</h2>
                    <p class="mt-2 text-sm text-gray-500">View and edit your personal details.</p>
                </a>

                <a href="/user/address" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-blue-50 text-blue-700">
                        <i class="fa-solid fa-address-card text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Addresses</h2>
                    <p class="mt-2 text-sm text-gray-500">Manage your saved addresses for faster checkout.</p>
                </a>

                <a href="/order/details" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-violet-50 text-violet-700">
                        <i class="fa-solid fa-box text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Orders</h2>
                    <p class="mt-2 text-sm text-gray-500">Track and manage your recent orders.</p>
                </a>

                <a href="/wishlist" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-rose-50 text-rose-700">
                        <i class="fa-solid fa-heart text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Wishlist</h2>
                    <p class="mt-2 text-sm text-gray-500">View and manage your saved items for later purchase.</p>
                </a>

                <a href="/user/wallet" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-emerald-50 text-emerald-700">
                        <i class="fa-solid fa-wallet text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Wallet</h2>
                    <p class="mt-2 text-sm text-gray-500">Check balance and see your wallet transactions.</p>
                </a>

                <a href="/cart" class="group border border-gray-100 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-amber-50 text-amber-700">
                        <i class="fa-solid fa-cart-shopping text-xl"></i>
                    </div>
                    <h2 class="text-lg font-medium text-gray-900">My Cart</h2>
                    <p class="mt-2 text-sm text-gray-500">Review your cart items and proceed to checkout.</p>
                </a>
            </div>
        </div>
    </section>    


    <%- include('partials/userFooter') %>
        

    <script src="/js/user/homePage.js"></script>
</body>
</html>
