<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/fonts.css">
    <title><%= title || "Camverse" %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
  
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


</head>
<body style="font-family:'Open Sans', sans-serif;">

  <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

  
  <div class="container mx-auto px-8 md:pl-20 md:pr-20 py-20 mt-8">


    <nav class="text-sm mb-2" aria-label="Breadcrumb">
      <ol class="list-reset flex text-gray-600">
        <li>
          <a href="/" class="hover:text-teal-500">Home</a>
        </li>
        <li><span class="mx-2">></span></li>

        <li>
          <a href="/shop" class="hover:text-teal-500">Shop</a>
        </li>
        <li><span class="mx-2">></span></li>

        <li class="text-gray-800 font-semibold line-clamp-2 truncate max-w-[150px]">
          <%= product.name %>
        </li>
      </ol>
    </nav>


    <div class="flex flex-col md:flex-row gap-10 mb-10">

      
      <div class="flex flex-col items-center space-y-6 md:w-1/6 mt-6">
        
        <div id="thumbnails-desktop" class="flex flex-col space-y-4 max-h-[400px] overflow-y-auto hidden md:flex">
          <% product.images.forEach((img, index) => { %>
            <img 
              src="<%= img.url || img.secure_url %>"  
              alt="Thumbnail <%= index + 1 %>" 
              class="w-20 h-20 object-contain border-2 cursor-pointer <%= index === 0 ? 'border-teal-500' : 'border-transparent' %>" 
              data-index="<%= index %>"
            />
          <% }) %>
        </div>

      </div>
  
     
      <div class="md:w-1/3 flex flex-col justify-start pt-12 relative">
        <div class="w-full h-[350px] flex items-center justify-center">
          <img 
          id="mainImage" 
          src="<%= product.images[0].url || product.images[0].secure_url %>" 
          alt="Product Image" 
          class="max-w-full max-h-[350px] object-contain cursor-zoom-in mb-8" 
          />
        </div>

        <div 
        id="zoomBox" 
        class="hidden bg-white fixed top-20 right-10 
               w-[300px] h-[300px]
               s600:w-[330px] s600:h-[330px] 
               xl1200:w-[400px] xl1200:h-[400px]
               xl1300:w-[400px] xl1300:h-[400px]
               xxl1400:w-[600px] xxl1400:h-[600px]
               xxl1500:w-[760px] xxl1500:h-[750px]
               border border-gray-200 
               bg-no-repeat z-50 shadow-lg mt-3">
               
      </div>


        <div id="thumbnails-mobile" class="flex justify-center space-x-4 max-h-[400px] overflow-y-auto md:hidden">
          <% product.images.forEach((img, index) => { %>
            <img 
              src="<%= img.url || img.secure_url %>"  
              alt="Thumbnail <%= index + 1 %>" 
              class="w-20 h-20 object-contain border-2 cursor-pointer <%= index === 0 ? 'border-black' : 'border-transparent' %>" 
              data-index="<%= index %>"
            />
          <% }) %>
        </div>

        <div class="flex flex-col text-xs md:tex-sm xl:flex-row gap-4 mt-6 font-semibold justify-center">

          <% if (isInCart) { %>
            <a
              href="/cart"
              class="bg-teal-700 text-white px-10 py-3 hover:bg-teal-800 w-full xl:w-auto inline-flex items-center justify-center gap-2 transition duration-150 ease-out transform active:scale-[0.95] active:shadow-inner"
            >
              <i class="fa-solid fa-cart-shopping"></i>
              SEE CART
            </a>
          <% } else { %>
            <form action="/cart/add" method="POST" class="w-full xl:w-auto">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <input type="hidden" name="quantity" value="1">
              <button 
                type="submit"
                class="bg-yellow-400 text-white px-10 py-3 hover:bg-yellow-500 disabled:bg-gray-300 disabled:cursor-not-allowed w-full xl:w-auto transition duration-150 ease-out transform active:scale-[0.95] active:shadow-inner"
                <%= product.stock === 0 ? "disabled" : "" %>>
                <i class="fa-solid fa-cart-shopping"></i>
                <span class="add-cart-label">ADD TO CART</span>
              </button>
            </form>
          <% } %>

          <form action="/wishlist/add" method="POST" class="inline">
            <input type="hidden" name="productId" value="<%= product._id %>">
            <input type="hidden" name="redirectTo" value="/product/<%= product._id %>">
            <button 
              type="submit"
              class="bg-red-500 text-white px-6 py-3 hover:bg-red-600 w-full transition duration-150 ease-out transform active:scale-[0.95] active:shadow-inner">
              <i class="fa-solid fa-heart"></i>
              <span class="add-wishlist-label">ADD TO WISHLIST</span>
            </button>
          </form>
        
        </div>
        
      </div>
  
      
      <div class="md:w-1/2 space-y-4 mt-4">
  
        <div>
          <h1 class="text-base md:text-xl font-semibold">
            <%= product.name %>
          </h1> 

          <p class="text-gray-400 text-sm">
            Brand: 
            <span class="text-blue-400 font-semibold text-sm">
              <%= product.brand ? product.brand.name : "N/A" %>
            </span>
          </p>
        </div>
  
        <div>
          <%
            const nowMain = new Date();
            const isOfferActiveMain = (offer) => {
              if (!offer || !offer.isActive) return false;
              if (!offer.discountValue || Number(offer.discountValue) <= 0) return false;
              const startsAt = offer.startDate ? new Date(offer.startDate) : null;
              const endsAt = offer.endDate ? new Date(offer.endDate) : null;
              if (startsAt && nowMain < startsAt) return false;
              if (endsAt && nowMain > endsAt) return false;
              return true;
            };
            const productOfferMain = isOfferActiveMain(product.individualOffer) ? product.individualOffer : null;
            const categoryOfferMain = isOfferActiveMain(product.category?.individualOffer) ? product.category.individualOffer : null;
            const activeOfferMain = productOfferMain || categoryOfferMain;
            const offerBadgeTextMain = activeOfferMain
              ? (activeOfferMain.discountType === "FLAT"
                  ? `EXTRA FLAT ₹${Number(activeOfferMain.discountValue).toLocaleString("en-IN")}`
                  : `EXTRA ${Number(activeOfferMain.discountValue)}% OFF`)
              : "";
          %>
          <p class="text-xl md:text-3xl font-bold">
            ₹<%= product.price.toLocaleString() %>
          </p>
          <% if (offerBadgeTextMain) { %>
            <p class="inline-block mt-2 px-2 py-1 rounded bg-orange-100 text-orange-700 text-xs font-semibold">
              <%= offerBadgeTextMain %>
            </p>
          <% } %>
          <p class="text-sm text-gray-600">(Incl. all Taxes)</p>

          <div class="flex items-center mt-1 gap-1 text-xs">
            <% const averageRating = Number(product.averageRating || 0); %>
            <% for (let i = 1; i <= 5; i++) { %>
              <% if (i <= Math.floor(averageRating)) { %>
                <i class="fa-solid fa-star text-yellow-400"></i>
              <% } else if (i - 0.5 <= averageRating) { %>
                <i class="fa-solid fa-star-half-stroke text-yellow-400"></i>
              <% } else { %>
                <i class="fa-solid fa-star text-gray-300"></i>
              <% } %>
            <% } %>
            <span class="ml-1 text-sm text-green-600">
              <%= Number(product.averageRating || 0).toFixed(1) %> (<%= Number(product.ratingCount || 0) %>)
            </span>
          </div>
        </div>


  
        <hr />
  
        <% if (product.mrp && product.mrp > product.price) { %>
          <p class="text-gray-400 line-through text-sm">
            MRP: ₹<%= product.mrp.toLocaleString() %>
          </p>
  
          <p class="text-sm text-green-600">
            (Save ₹<%= (product.mrp - product.price).toLocaleString() %>, 
            <%= Math.round(((product.mrp - product.price) / product.mrp) * 100) %>% Off)
          </p>
        <% } %>


        <% if (product.stock == 0) { %>
          <div>
            <h2 class="font-bold text-2xl">Sold Out</h2>
            <p class="text-red-500 text-xl">This item is currently out of stock</p>
          </div>
        <% } else if (product.stock <= 3) {%>
          <p class="text-red-500 text-sm">
            Hurry, Only <%= product.stock %> left!
          </p>
        <% } else if (product.stock <= 8) { %>
          <p class="text-orange-400 text-sm">
            Selling fast only <%= product.stock %> left!
          </p>
        <% } else if (product.stock <= 15) { %> 
          <p class="text-green-500 text-sm">
            In stock <%= product.stock %> - Ready to ship!
          </p>
        <% } %>  
  
        <div class="border border-gray-300 rounded-xl p-6 mt-4">
          <strong class="block mb-2">Features</strong>
          <p class="text-sm text-gray-700 whitespace-pre-line"><%= product.description %></p>
        </div>

        </div>
  
      </div>

    </div>

    <hr class="max-w-[1000px] mx-auto border-gray-300">

    <h2 class="text-2xl text-center font-semibold mt-10 mb-5 text-teal-500">Related Products</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 p-2 justify-center max-w-[800px] mx-auto mb-16">
      <% relatedProducts.forEach(rp => { %>
        <%
          const now = new Date();
          const isOfferActive = (offer) => {
            if (!offer || !offer.isActive) return false;
            if (!offer.discountValue || Number(offer.discountValue) <= 0) return false;
            const startsAt = offer.startDate ? new Date(offer.startDate) : null;
            const endsAt = offer.endDate ? new Date(offer.endDate) : null;
            if (startsAt && now < startsAt) return false;
            if (endsAt && now > endsAt) return false;
            return true;
          };
          const productOffer = isOfferActive(rp.individualOffer) ? rp.individualOffer : null;
          const categoryOffer = isOfferActive(rp.category?.individualOffer) ? rp.category.individualOffer : null;
          const activeOffer = productOffer || categoryOffer;
          const offerBadgeText = activeOffer
            ? (activeOffer.discountType === "FLAT"
                ? `EXTRA FLAT ₹${Number(activeOffer.discountValue).toLocaleString("en-IN")}`
                : `EXTRA ${Number(activeOffer.discountValue)}% OFF`)
            : "";
        %>
        <div class="relative border p-4 shadow-xl hover:shadow-2xl rounded-lg max-w-[220px] md:max-w-[170px] mx-auto mb-5">
          <% if (offerBadgeText) { %>
            <div class="absolute top-2 left-2 z-10 bg-orange-500 text-white text-[10px] font-semibold px-2 py-1 rounded">
              <%= offerBadgeText %>
            </div>
          <% } %>
          <a href="/product/<%= rp._id %>" class="block">
            <img src="<%= rp.images[0].url %>" 
                 alt="<%= rp.name %>" 
                 class="w-full h-28 object-contain rounded transition duration-300 hover:scale-110 mb-2">
    
            <h3 class="mt-1 text-sm font-extralight line-clamp-2 truncate">
              <%= rp.name %>
            </h3>
    
            <p class="text-gray-800 font-bold text-sm">₹<%= rp.price.toLocaleString() %></p>
    
            <% if (rp.mrp && rp.mrp > rp.price) { %>
              <p class="text-gray-400 line-through text-xs">
                MRP: ₹<%= rp.mrp.toLocaleString() %>
              </p>
              <p class="text-xs text-green-600">
                (Save ₹<%= (rp.mrp - rp.price).toLocaleString() %>, 
                <%= Math.round(((rp.mrp - rp.price) / rp.mrp) * 100) %>% OFF)
              </p>
            <% } %>
          </a>
        </div>
      <% }) %>
    </div>

    <%- include('partials/productReviews') %>


    <div id="toast" 
      class="fixed bottom-5 left-1/2 transform -translate-x-1/2 
              bg-black text-white px-4 py-3 shadow-lg 
              opacity-0 translate-y-10 transition-all duration-500">
    </div>

    <script>
      // Helper to show toast
      function showToast(message) {
        const toast = document.getElementById('toast');
        toast.innerText = message;
        toast.classList.remove('opacity-0', 'translate-y-10');
        toast.classList.add('opacity-100', 'translate-y-0');

        setTimeout(() => {
          toast.classList.remove('opacity-100', 'translate-y-0');
          toast.classList.add('opacity-0', 'translate-y-10');
        }, 3000); // auto-hide in 3s
      }

      // Check query params
      const params = new URLSearchParams(window.location.search);
      if (params.get("status") === "added") {
        showToast("✅ Product added to wishlist");
      }
      if (params.get("status") === "exists") {
        showToast("⚠️ Product already in wishlist");
      }
      if (params.get("cartStatus") === "added") {
        showToast("✅ Product added to cart");
      }
      if (params.get("cartStatus") === "exists") {
        showToast("⚠️ Product already in cart");
      }
      if (params.get("reviewStatus") === "added") {
        showToast("✅ Review submitted");
      }
      if (params.get("reviewStatus") === "updated") {
        showToast("✅ Review updated");
      }
      if (params.get("reviewStatus") === "deleted") {
        showToast("✅ Review deleted");
      }
      if (params.get("reviewStatus") === "notEligible") {
        showToast("⚠️ You can review only delivered products");
      }
      if (params.get("reviewStatus") === "invalid") {
        showToast("⚠️ Please choose a valid rating");
      }
      if (params.get("reviewStatus") === "error") {
        showToast("⚠️ Could not save review");
      }

      const reviewMenuBtn = document.getElementById("reviewMenuBtn");
      const reviewMenu = document.getElementById("reviewMenu");
      const editReviewBtn = document.getElementById("editReviewBtn");
      const editReviewForm = document.getElementById("editReviewForm");
      const cancelEditReviewBtn = document.getElementById("cancelEditReviewBtn");

      reviewMenuBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        reviewMenu?.classList.toggle("hidden");
      });

      editReviewBtn?.addEventListener("click", () => {
        reviewMenu?.classList.add("hidden");
        editReviewForm?.classList.remove("hidden");
        editReviewForm?.scrollIntoView({ behavior: "smooth", block: "center" });
      });

      cancelEditReviewBtn?.addEventListener("click", () => {
        editReviewForm?.classList.add("hidden");
      });

      document.addEventListener("click", (e) => {
        if (!reviewMenuBtn || !reviewMenu) return;
        const clickedInside = reviewMenuBtn.contains(e.target) || reviewMenu.contains(e.target);
        if (!clickedInside) {
          reviewMenu.classList.add("hidden");
        }
      });

      const paintStars = (widget, ratingValue) => {
        const stars = widget.querySelectorAll("[data-star-index]");
        stars.forEach((star) => {
          const idx = Number(star.dataset.starIndex);
          star.classList.remove("fa-star", "fa-star-half-stroke", "text-yellow-400", "text-gray-300");
          if (idx <= Math.floor(ratingValue)) {
            star.classList.add("fa-star", "text-yellow-400");
          } else if (idx - 0.5 === ratingValue) {
            star.classList.add("fa-star-half-stroke", "text-yellow-400");
          } else {
            star.classList.add("fa-star", "text-gray-300");
          }
        });
      };

      document.querySelectorAll(".rating-widget").forEach((widget) => {
        const input = widget.parentElement.querySelector(".rating-value");
        const errorText = widget.parentElement.querySelector(".rating-error");
        const form = widget.closest("form");
        const initial = Number(widget.dataset.initialRating || input?.value || 0);
        if (initial > 0) {
          input.value = initial;
          paintStars(widget, initial);
        } else {
          paintStars(widget, 0);
        }

        widget.querySelectorAll("[data-star-index]").forEach((star) => {
          star.addEventListener("click", (event) => {
            const idx = Number(star.dataset.starIndex);
            const rect = star.getBoundingClientRect();
            const isLeftHalf = event.clientX - rect.left < rect.width / 2;
            const selected = isLeftHalf ? idx - 0.5 : idx;
            input.value = selected;
            paintStars(widget, selected);
            if (errorText) {
              errorText.classList.add("hidden");
            }
          });
        });

        form?.addEventListener("submit", (event) => {
          const selected = Number(input?.value || 0);
          if (!Number.isFinite(selected) || selected <= 0) {
            event.preventDefault();
            if (errorText) {
              errorText.classList.remove("hidden");
            }
          }
        });
      });
    </script>
    
  </div>
  


  <%- include('partials/userFooter') %>


  <script src="https://unpkg.com/medium-zoom@1.0.6/dist/medium-zoom.min.js"></script>

  <script src="/js/user/productDetails.js"></script>
  

</body>
</html>     
