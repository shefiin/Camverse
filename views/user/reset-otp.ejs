<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Reset password OTP</title>
    <link rel="stylesheet" href="/css/tailwind.css">
  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body class="min-h-screen bg-cover bg-center flex items-center justify-center" style="background-image: url('/images/supermassive-black-hole.webp');">
    <div class="bg-white p-10 shodow-lg w-full max-w-[380px]">
       <h2 class="text-xl font-semibold text-gray-600 mb-6" style="font-family: 'Michroma',sans-serif;">Camverse</h2>
        <h1 class="text-xl font-semibold mb-6" style="font-family: Inter, sans-serif;">Reset password OTP</h1>
        <p class="text-gray-600 font-extralight mb-6">Enter the OTP sent to your email <span class="text-blue-600"><%= email %></span></p>
        
        <form action="/reset/otp" method="POST" id="resetOtpForm">
            <label class="block text-sm font-medium text-gray-700 mb-1" for=""></label>
            <input 
                type="text" 
                name="otp" 
                id="otpInput"
                maxlength="6"
                placeholder="Enter 6-digit OTP"
                class="w-full px-4 py-2 font-extralight border mb-2
                    <%= error ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-400' %>"
                
            />

            <% if (error) { %>
                <p class="text-red-500 text-sm mb-4"><%= error %></p>
            <% } %>
                
                <div 
                    id="timer-container" 
                    data-remaining-resend="<%= remainingResend %>"
                    data-resend-allowed-at="<%= resendAllowedAt || '' %>">
                    
                    <span id="timer" class="text-gray-400 font-medium"></span>
                    
                    <a 
                    href="/reset/resend-otp"
                    id="resend-link" 
                    class="text-gray-400 text-sm font-extralight cursor-not-allowed pointer-events-none ml-2">
                    Resend OTP
                    </a>
                </div>
          
    
                <button id="otpSubmitBtn" type="submit" disabled class="w-full bg-gray-300 text-white font-semibold px-4 py-2 transition-duration-200 mt-6 cursor-not-allowed active:scale-[0.95] transition duration-150 ease-out transform">
                    SUBMIT
                </button>
        </form>
    </div>

    <script>
        const container = document.getElementById('timer-container');
        const resendAllowedAtRaw = container.dataset.resendAllowedAt;
        const resendAllowedAt = resendAllowedAtRaw ? parseInt(resendAllowedAtRaw, 10) : null;
        let timer = resendAllowedAt
          ? Math.max(0, Math.ceil((resendAllowedAt - Date.now()) / 1000))
          : (parseInt(container.dataset.remainingResend, 10) || 0);

        const resendLink = document.getElementById('resend-link');
        const timerDisplay = document.getElementById('timer');

        const interval = setInterval(() => {
            if (timer > 0) {
            timerDisplay.textContent = `Resend available in ${timer--}s`;
            resendLink.classList.add('text-gray-400', 'cursor-not-allowed', 'pointer-events-none');
            resendLink.classList.remove('text-blue-600', 'cursor-pointer', 'hover:underline');
            } else {
            clearInterval(interval);
            timerDisplay.textContent = '';
            resendLink.classList.remove('text-gray-400', 'cursor-not-allowed', 'pointer-events-none');
            resendLink.classList.add('text-blue-600', 'cursor-pointer', 'hover:underline');
            }
        }, 1000);

        const otpInput = document.getElementById('otpInput');
        const otpSubmitBtn = document.getElementById('otpSubmitBtn');

        function toggleOtpSubmit() {
          const value = (otpInput.value || '').replace(/\D/g, '').slice(0, 6);
          otpInput.value = value;
          const isValid = value.length === 6;
          otpSubmitBtn.disabled = !isValid;
          if (isValid) {
            otpSubmitBtn.classList.remove('bg-gray-300', 'cursor-not-allowed');
            otpSubmitBtn.classList.add('bg-gray-800', 'hover:bg-gray-900', 'cursor-pointer');
          } else {
            otpSubmitBtn.classList.remove('bg-gray-800', 'hover:bg-gray-900', 'cursor-pointer');
            otpSubmitBtn.classList.add('bg-gray-300', 'cursor-not-allowed');
          }
        }

        otpInput.addEventListener('input', toggleOtpSubmit);
        otpInput.addEventListener('paste', () => setTimeout(toggleOtpSubmit, 0));
        toggleOtpSubmit();

    </script>
    
</body>
</html>
