<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/fonts.css">
    <title>Camverse</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/tailwind.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    

</head>
<body style="font-family:'Open Sans', sans-serif;">
    
    <%- include('partials/userNavbar', { navbarTheme: 'dark', navbarLightOnScrollAt: 920 }) %>

      <section
  class="w-full h-[1000px] bg-cover bg-[center_top_-50px] md:bg-center relative"
  style="background-image: url('/images/BannerHero.webp');"
>

        <div class="absolute inset-0 flex flex-col justify-between px-6 md:px-16 py-8 text-white">
            <div class="flex flex-col items-center space-y-4 py-20" style="font-family: 'Jost', sans-serif;">
                <img src="/images/z8logo.jpg" alt="Nikon z8 logo" class="h-6 sm:h-9 md:h-12 w-auto object-contain">
                <h1 class="text-4xl md:text-6xl tracking-widest font-medium  bg-gradient-to-r from-blue-500 via-sky-400 to-cyan-300 bg-clip-text text-transparent">READY. ACTION.</h1>
            </div>

            <div class="flex flex-col gap-y-2 items-center space-y-3 text-center">
                <h2 class="text-2xl md:text-4xl font-medium bg-gradient-to-b from-gray-100 via-gray-300 to-gray-500 bg-clip-text text-transparent drop-shadow-md mb-4">The Ultimate Hybrid Camera</h2>
                <p class="text-sm md:text-lg max-w-xl text-gray-200">
                    Powerful performance. Professional build. Compact, lightweight handling. A dream camera for videos and stills.
                </p>
                <h2 class="text-2xl md:text-3xl font-bold text-gray-300">
                    Starting at <span class="text-white font-bold">₹ 59,999</span>
                </h2>
                <a href="/product/689c4c227d84392071689a81" class="border border-white text-white px-4 py-2 rounded-3xl font-medium bg-transparent hover:bg-white hover:text-black transition-duration-300">
                    Shop Now
                </a>         
            </div>

        </div>
      </section>

      <div class="relative overflow-hidden">
        <div class="pointer-events-none absolute -top-16 -left-20 h-72 w-72 rounded-full bg-gradient-to-br from-cyan-300/25 to-transparent blur-3xl"></div>
        <div class="pointer-events-none absolute top-1/3 -right-20 h-80 w-80 rounded-full bg-gradient-to-br from-blue-300/25 to-transparent blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 left-1/3 h-72 w-72 rounded-full bg-gradient-to-br from-teal-300/20 to-transparent blur-3xl"></div>
        <div class="pointer-events-none absolute inset-0 opacity-95"
             style="background:
                radial-gradient(circle at 8% 12%, rgba(20,184,166,0.14), transparent 36%),
                radial-gradient(circle at 88% 15%, rgba(59,130,246,0.12), transparent 38%),
                radial-gradient(circle at 20% 78%, rgba(56,189,248,0.10), transparent 40%),
                radial-gradient(circle at 86% 86%, rgba(45,212,191,0.09), transparent 44%),
                linear-gradient(180deg, #f5f9ff 0%, #eef4ff 34%, #eef7fb 68%, #f6fbff 100%);">
        </div>
        <div class="pointer-events-none absolute inset-0 opacity-[0.10]"
             style="background-image:
                repeating-linear-gradient(0deg, rgba(31,41,55,0.08) 0px, rgba(31,41,55,0.08) 1px, transparent 1px, transparent 4px),
                repeating-linear-gradient(90deg, rgba(31,41,55,0.05) 0px, rgba(31,41,55,0.05) 1px, transparent 1px, transparent 5px);">
        </div>

      <div class="relative z-10">
      <section class="px-14 md:px-16 py-12 space-y-24">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-center mb-2 mt-20 text-gray-600">Shop by Category</h1>
          <p class="text-sm md:text-base text-center text-gray-600 mb-12">Find the perfect camera for every moment — from professional shoots to everyday snaps.

          </p>
        </div>
        
        <% categories.forEach(category => { %>
          <div class="text-center">
            <img src="<%= category.image[0].url %>" alt="<%= category.name %>" 
                 class="mx-auto w-full max-w-5xl h-auto" />
            
            <h1 class="text-2xl md:text-4xl font-bold mt-6"><%= category.name %> Cameras</h1>
            <p class="text-sm md:text-base  text-gray-600 mt-2 max-w-xl mx-auto">
              <%= category.description %>
            </p>
            <a href="/shop?category=<%= category._id %>" 
               class="inline-block mt-4 text-black px-6 py-2 rounded-3xl transition-colors duration-200" 
               style="background-color: #ffd500;" 
               onmouseover="this.style.backgroundColor='#DCB800'" 
               onmouseout="this.style.backgroundColor='#ffd500'">
              SHOP NOW
            </a>
          </div>
        <% }) %>
      </section>
             
      <section class="py-12">
        <h2 class="text-center text-3xl md:text-4xl font-bold text-gray-700 mb-2">
          Pick Your Camera Brand
        </h1>
        <p class="text-center text-gray-600 mb-8">
          Explore trusted brands that define photography excellence.
        </p>  

        <div class="flex justify-center items-center gap-6 overflow-x-auto px-4 md:px-16">
          <% brands.forEach(brand => { %>
            <a href="/shop?brand=<%= brand._id %>">
              <img src="<%= brand.image[0].url %>" alt="<%= brand.name %>">
            </a>
          <% }) %>
        </div>
      </section>

      <section class="px-4 md:px-16 py-12">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-center text-3xl md:text-4xl font-bold text-gray-700 mb-2">FAQs</h2>
          <p class="text-center text-gray-600 mb-8">Quick answers about ordering cameras on Camverse.</p>

          <div class="space-y-3">
            <div class="faq-item border border-gray-200 rounded-xl bg-white overflow-hidden">
              <button type="button" class="faq-toggle w-full flex items-center justify-between px-5 py-4 text-left">
                <span class="font-medium text-gray-800">Are all cameras listed on Camverse genuine?</span>
                <i class="fa-solid fa-plus text-gray-500 faq-icon"></i>
              </button>
              <div class="faq-content hidden px-5 pb-4 text-sm text-gray-600">
                Yes. We list only original products from trusted brands and verified sources.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl bg-white overflow-hidden">
              <button type="button" class="faq-toggle w-full flex items-center justify-between px-5 py-4 text-left">
                <span class="font-medium text-gray-800">Can I return a product after delivery?</span>
                <i class="fa-solid fa-plus text-gray-500 faq-icon"></i>
              </button>
              <div class="faq-content hidden px-5 pb-4 text-sm text-gray-600">
                Yes, eligible delivered orders can be returned from your order details page.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl bg-white overflow-hidden">
              <button type="button" class="faq-toggle w-full flex items-center justify-between px-5 py-4 text-left">
                <span class="font-medium text-gray-800">How fast is shipping?</span>
                <i class="fa-solid fa-plus text-gray-500 faq-icon"></i>
              </button>
              <div class="faq-content hidden px-5 pb-4 text-sm text-gray-600">
                Delivery timelines vary by location, but most orders are shipped quickly with tracking updates.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl bg-white overflow-hidden">
              <button type="button" class="faq-toggle w-full flex items-center justify-between px-5 py-4 text-left">
                <span class="font-medium text-gray-800">Do you support wallet and online payments?</span>
                <i class="fa-solid fa-plus text-gray-500 faq-icon"></i>
              </button>
              <div class="faq-content hidden px-5 pb-4 text-sm text-gray-600">
                Yes. You can pay via online methods, wallet balance, or a combination when available.
              </div>
            </div>
          </div>
        </div>
      </section>
      </div>
      </div>

      <%- include('partials/userFooter') %>

      <script src="/js/user/homePage.js"></script>
      <script>
        document.querySelectorAll(".faq-toggle").forEach((btn) => {
          btn.addEventListener("click", () => {
            const item = btn.closest(".faq-item");
            const content = item?.querySelector(".faq-content");
            const icon = item?.querySelector(".faq-icon");
            if (!content || !icon) return;
            content.classList.toggle("hidden");
            icon.classList.toggle("fa-plus");
            icon.classList.toggle("fa-minus");
          });
        });
      </script>

</body>
</html>

 
