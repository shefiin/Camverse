<%
  const isLightNavbar = typeof navbarTheme !== "undefined" && navbarTheme === "light";
  const scrollLightAt = typeof navbarLightOnScrollAt !== "undefined" ? Number(navbarLightOnScrollAt) : null;
  const navBgClass = isLightNavbar ? "bg-white" : "bg-black";
  const brandTextClass = isLightNavbar ? "text-gray-900" : "text-gray-400";
  const navTextClass = isLightNavbar ? "text-gray-700" : "text-gray-400";
  const navHoverTextClass = isLightNavbar ? "hover:text-gray-900" : "hover:text-gray-300";
  const searchBoxClass = isLightNavbar ? "bg-white border-gray-300" : "bg-gray-900 border-gray-300";
  const searchInputClass = isLightNavbar ? "bg-white text-gray-700" : "bg-gray-900 text-gray-300";
  const searchIconHoverClass = isLightNavbar ? "hover:text-gray-700" : "hover:text-gray-300";
  const iconTextClass = isLightNavbar ? "text-gray-700" : "text-gray-500";
  const iconHoverClass = isLightNavbar ? "hover:text-gray-900" : "hover:text-gray-300";
%>
<nav
  id="navbar"
  data-scroll-light-at="<%= Number.isFinite(scrollLightAt) ? scrollLightAt : '' %>"
  class="<%= navBgClass %> transition-all duration-300 py-2 shadow-md fixed top-0 left-0 w-full z-50"
>
    <div class="w-full px-12 py-4 flex items-center justify-between">

        <div class="flex-1">
            <a href="/" class="text-xl tablet:text-2xl font-bold <%= brandTextClass %>" style="font-family: 'Michroma', sans-serif;">Camverse</a>
        </div>


        <ul id="nav-links" class="hidden tablet:flex space-x-8 text-sm font-medium <%= navTextClass %>">
            <li><a href="/" class="hover:underline <%= navHoverTextClass %>">Home</a></li>
            <li><a href="/shop" class="hover:underline <%= navHoverTextClass %>">Shop</a></li>
            

            <li class="relative group">
                <a href="" class="hover:underline <%= navHoverTextClass %>">Brands</a>
                <ul class="absolute left-0 top-full bg-white shadow-md w-40 hidden group-hover:block z-50">
                    <% brands.forEach(brand => { %>
                        <li><a href="/shop/brand/<%= brand._id %>" class="block px-4 py-2 hover:bg-gray-100"><%= brand.name %></a></li>
                    <% }) %>
                </ul>
            </li>
            <li class="relative group">
                <a href="" class="hover:underline <%= navHoverTextClass %>">Categories</a>
                <ul class="absolute left-0 top-full bg-white shadow-md w-40 hidden group-hover:block z-50">
                    <% categories.forEach(category => { %>
                        <li><a href="/shop/category/<%= category._id %>"  class="block px-4 py-2 hover:bg-gray-100"><%= category.name %></a></li>
                    <% }) %>
                </ul>
            </li>
            <li><a href="/about" class="hover:underline <%= navHoverTextClass %>">About</a></li>
        </ul>

        <div class="relative ml-5 w-[150px] md:w-[200px] flex-shrink-0">
            <form id="search-form" action="/search" method="GET" class="flex items-center border overflow-hidden <%= searchBoxClass %>">
              <input
                id="search-input" 
                type="text" 
                name="search" 
                value="<%= typeof search !== 'undefined' ? search : '' %>" 
                placeholder="Search..." 
                class="flex-grow min-w-0 px-2 py-1 text-sm focus:outline-none <%= searchInputClass %>"
              />
              <button type="submit" class="flex-shrink-0 px-2 text-gray-600 <%= searchIconHoverClass %> active:scale-[0.95] transition duration-150 ease-out transform">
                <i class="fas fa-search"></i>
              </button>
              <% if (typeof search !== 'undefined' && search.trim() !== '') { %>
                <button type="button" id="clear-search" class="hidden flex-shrink-0 text-gray-400 hover:text-black px-2 active:scale-[0.95] transition duration-150 ease-out transform">
                    <i class="fas fa-times"></i>
                </button>
              <% } %>
            </form>
          </div>
          

        <div id="login-toggle" class="flex items-center space-x-6 <%= iconTextClass %> ml-10">

            <a href="/cart" class="<%= iconHoverClass %> flex items-center space-x-1">
              <i class="fa fa-cart-shopping text-xl tablet:text-2xl"></i>  
            </a>

            <div class="relative group flex items-center space-x-1">
                <a id="login-click" href="#" class="flex items-center space-x-1">
                    <i class="fa-solid fa-user text-xl tablet:text-2xl"></i>
                                      
                </a>
                
                  <ul id="login-dropdown" class="absolute right-0 top-full bg-white shadow-md w-44 hidden z-50">
                    <% if (user) { %>
                      <li class="block px-4 py-2 hover:bg-gray-100 text-xl text-gray-700">
                        Hello, <%= user.name %>
                      </li>
                      <li><a href="/user/account" class="block px-4 py-2 hover:bg-gray-100 hover:text-gray-600 font-extralight">
                        <i class="fa-solid fa-user mr-2"></i>My Account
                      </a></li>
                      <li><a href="/order/details" class="block px-4 py-2 hover:bg-gray-100 hover:text-gray-600 font-extralight">
                        <i class="fa-solid fa-bag-shopping mr-2"></i>Orders
                      </a></li>
                      <li><a href="/wishlist" class="block px-4 py-2 hover:bg-gray-100 hover:text-gray-600 font-extralight">
                        <i class="fa-solid fa-heart mr-2"></i>Wishlist
                      </a></li>
                      <li><a href="/logout" class="block px-4 py-2 hover:bg-gray-100 text-red-600 font-extralight">
                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                      </a></li>
                    <% } else { %>
                      <li class="px-3 pt-3 pb-2 border-b border-gray-100">
                        <p class="text-[11px] uppercase tracking-wide text-gray-400 mb-2">Welcome to Camverse</p>
                        <div class="space-y-2">
                          <a href="/login" class="w-full block text-center bg-gray-900 text-white py-2 text-sm font-medium hover:bg-black transition duration-150 ease-out active:scale-[0.95] transform">
                             Login
                          </a>
                          <a href="/register" class="w-full block text-center bg-gray-100 text-gray-700 py-2 text-sm font-medium hover:bg-gray-200 transition duration-150 ease-out active:scale-[0.95] transform">
                            <i class="fa-solid fa-user-plus mr-1"></i> Register
                          </a>
                        </div>
                      </li>
                      <li><a href="/user/account" class="block px-4 py-2 hover:bg-gray-100 font-extralight">
                        <i class="fa-solid fa-user mr-2"></i>My Account
                      </a></li>
                      <li><a href="/order/details" class="block px-4 py-2 hover:bg-gray-100 font-extralight">
                        <i class="fa-solid fa-bag-shopping mr-2"></i>Orders
                      </a></li>
                      <li><a href="/user/wishlist" class="block px-4 py-2 hover:bg-gray-100 font-extralight">
                        <i class="fa-solid fa-heart mr-2"></i>Wishlist
                      </a></li>
                    <% } %>
                  </ul>

                      
                </ul>
            </div>  
        </div>

        <button id="menu-toggle" class="tablet:hidden ml-5 text-xl <%= isLightNavbar ? 'text-gray-700' : 'text-gray-300' %> active:scale-[0.95] transition duration-150 ease-out transform">
            <i class="fas fa-bars"></i>
        </button>

    </div>
</nav>

<ul id="menu" class="hidden mt-20 flex flex-col px-6 py-4 <%= isLightNavbar ? 'bg-white' : 'bg-black' %> shadow-md tablet:hidden space-y-4 text-sm font-medium <%= isLightNavbar ? 'text-gray-700' : 'text-gray-300' %>">
    <li><a href="/">Home</a></li>
    <li><a href="/shop">Shop</a></li>
    <li><a href="/about">About</a></li>
    <li>
        <a href="#" id="brand-link" class="inline-flex items-center">
            Brands
            <i class="fas fa-chevron-down text-xs ml-2"></i>
        </a>
        <ul id="brands-submenu" class="hidden flex-col space-y-2 pl-4 <%= isLightNavbar ? 'bg-gray-100 text-gray-700' : 'bg-gray-800 text-gray-300' %> text-sm mt-2">
            <% brands.forEach(brand => { %>
                <li><a href="/shop?brand=<%= brand.name %>"><%= brand.name %></a></li>
            <% }) %>        
        </ul>
    </li>

    <li>
        <a href="#" id="category-link" class="inline-flex items-center">
            Categories
            <i class="fas fa-chevron-down text-xs ml-2"></i>
        </a>
        <ul id="categories-submenu" class="hidden flex-col space-y-2 pl-4 <%= isLightNavbar ? 'bg-gray-100 text-gray-700' : 'bg-gray-800 text-gray-300' %> text-sm mt-2">
            <% categories.forEach(cat => { %>
                <li><a href="/shop?category=<%= cat.name %>"><%= cat.name %></a></li>
            <% }) %>
        </ul>
    </li>
</ul>



<style>
  #navbar.scrolled-light {
    background-color: #ffffff !important;
  }
  #navbar.scrolled-light #nav-links > li > a,
  #navbar.scrolled-light #login-toggle > a,
  #navbar.scrolled-light #login-click {
    color: #374151 !important;
  }
  #navbar.scrolled-light #nav-links > li > a:hover,
  #navbar.scrolled-light #login-toggle > a:hover,
  #navbar.scrolled-light #login-click:hover {
    color: #111827 !important;
  }
  #navbar.scrolled-light #search-form {
    background-color: #ffffff !important;
    border-color: #d1d5db !important;
  }
  #navbar.scrolled-light #search-input {
    background-color: #ffffff !important;
    color: #374151 !important;
  }
  #navbar.scrolled-light #menu-toggle {
    color: #374151 !important;
  }
</style>
