<!-- Cancel Reason Modal -->
<div id="returnModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 p-6">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Return Order</h2>
      <p class="text-sm text-gray-600 mb-1">Please select a reason for return:</p>
      <hr class="mb-4">
      <form id="returnForm" action="/order/return/<%= order._id %>?_method=PATCH" method="POST">
        <!-- Options -->
        <div class="space-y-2">
          <label class="flex items-center gap-2">
            <input type="radio" name="reason" value="Received wrong product" class="text-teal-600">
            <span>Received wrong product</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason" value="Product is defective" class="text-teal-600">
            <span>Product is defective</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason" value="Quality not as expected" class="text-teal-600">
            <span>Quality not as expected</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason" value="Other" class="text-teal-600" id="reasonOther">
            <span>Other</span>
          </label>
        </div>
  
        <!-- Custom Textarea -->
        <textarea 
          id="customReason"
          name="customReason" 
          rows="3" 
          placeholder="Please specify your reason..." 
          class="hidden mt-3 w-full border rounded-md p-2 text-sm focus:ring-2 focus:ring-teal-500 focus:outline-none"
        ></textarea>
  
        <!-- Buttons -->
        <div class="mt-6 flex justify-center gap-3">
          <button id="closeReturn" type="button" class="px-4 w-full py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300 active:scale-[0.95] transition duration-150 ease-out transform">
            Close
          </button>
          <button type="submit" class="px-4 py-2 bg-orange-400 text-white w-full rounded-md hover:bg-orange-500 active:scale-[0.95] transition duration-150 ease-out transform">
            Confirm Return
          </button>
        </div>
      </form>
    </div>
  </div>


  <!-- Product Return Modal -->
  <div id="returnProductModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 p-6">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Return Product</h2>
      <p class="text-sm text-gray-600 mb-1">Please select a reason for return:</p>
      <p id="couponReturnWarning" class="hidden mt-2 mb-1 rounded-md border border-orange-200 bg-orange-50 px-3 py-2 text-xs text-orange-700"></p>
      <hr class="mb-4">
      <form id="returnProductForm" action="" method="POST">
        <div id="returnQtyWrap" class="mb-3 hidden">
          <label for="returnQuantity" class="block text-sm text-gray-700 mb-1">Return Quantity</label>
          <select id="returnQuantity" name="returnQuantity" class="w-full border rounded-md p-2 text-sm focus:ring-2 focus:ring-teal-500 focus:outline-none">
            <option value="1">1</option>
          </select>
        </div>

        <!-- Options -->
        <div class="space-y-2">
          <label class="flex items-center gap-2">
            <input type="radio" name="reason2" value="Received wrong product" class="text-teal-600">
            <span>Received wrong product</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason2" value="Product is defective" class="text-teal-600">
            <span>Product is defective</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason2" value="Delivery time too long" class="text-teal-600">
            <span>Quality not as expected</span>
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="reason2" value="Other" class="text-teal-600" id="productReasonOther">
            <span>Other</span>
          </label>
        </div>

        <!-- Custom Textarea -->
        <textarea 
          id="productCustomReason"
          name="productCustomReason" 
          rows="3" 
          placeholder="Please specify your reason..." 
          class="hidden mt-3 w-full border rounded-md p-2 text-sm focus:ring-2 focus:ring-teal-500 focus:outline-none"
        ></textarea>

        <!-- Buttons -->
        <div class="mt-6 flex justify-center gap-3">
          <button id="closeProductReturn" type="button" class="px-4 w-full py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300 active:scale-[0.95] transition duration-150 ease-out transform">
            Close
          </button>
          <button type="submit" class="px-4 py-2 bg-orange-400 text-white w-full rounded-md hover:bg-orange-500 active:scale-[0.95] transition duration-150 ease-out transform">
            Confirm Return
          </button>
        </div>
      </form>
    </div>
  </div>



<script>
  (() => {
    const returnOrder = document.getElementById("returnOrder");
    const returnModal = document.getElementById("returnModal");
    const customReason = document.getElementById("customReason");
    const reasonOther = document.getElementById("reasonOther");
    const closeReturn = document.getElementById("closeReturn");

    const returnProduct = document.querySelectorAll(".returnProduct");
    const returnProductModal = document.getElementById("returnProductModal");
    const returnProductForm = document.getElementById("returnProductForm");
    const productCustomReason = document.getElementById("productCustomReason");
    const productReasonOther = document.getElementById("productReasonOther");
    const closeProductReturn = document.getElementById("closeProductReturn");


  
    function openReturnModal() {
      if (!returnModal) return;
      returnModal.classList.remove("hidden");
      returnModal.classList.add("flex");
    }
  
    function closeReturnModal() {
      if (!returnModal) return;
      returnModal.classList.add("hidden");
      returnModal.classList.remove("flex");
    }

    if (returnOrder) {
      returnOrder.addEventListener("click", () => {
        openReturnModal();
      });
    }

    if (closeReturn) {
      closeReturn.addEventListener("click", () => {
        closeReturnModal();
      });
    }

    // Show textarea only if "Other" is selected
    document.querySelectorAll("input[name='reason']").forEach(radio => {
      radio.addEventListener("change", () => {
        if (reasonOther && reasonOther.checked) {
          customReason.classList.remove("hidden");
        } else {
          customReason.classList.add("hidden");
          customReason.value = "";
        }
      });
    });



    const couponReturnWarning = document.getElementById("couponReturnWarning");
    const returnQtyWrap = document.getElementById("returnQtyWrap");
    const returnQuantitySelect = document.getElementById("returnQuantity");

    function toggleCouponWarning(meta) {
      if (!couponReturnWarning) return;
      if (!meta) {
        couponReturnWarning.textContent = "";
        couponReturnWarning.classList.add("hidden");
        return;
      }

      const qty = Number(returnQuantitySelect?.value || 1);
      const remainingSubtotal = Math.max(0, Number(meta.activeSubtotal || 0) - (Number(meta.unitPrice || 0) * qty));
      const isWholeOrderReturn = remainingSubtotal <= 0;
      const shouldWarn =
        !isWholeOrderReturn &&
        Number(meta.couponDiscount || 0) > 0 &&
        Number(meta.minPurchase || 0) > 0 &&
        remainingSubtotal < Number(meta.minPurchase || 0);

      if (shouldWarn) {
        couponReturnWarning.textContent =
          `You applied ${meta.code} for this order. If you return this product, you will get refund after coupon deduction.`;
        couponReturnWarning.classList.remove("hidden");
      } else {
        couponReturnWarning.textContent = "";
        couponReturnWarning.classList.add("hidden");
      }
    }

    function openProductReturnModal(actionUrl, meta) {
      if (!returnProductModal) return;
      if (returnProductForm && actionUrl) {
        returnProductForm.action = actionUrl;
      }

      const maxQty = Math.max(1, Number(meta?.maxQty || 1));
      if (returnQuantitySelect) {
        returnQuantitySelect.innerHTML = "";
        for (let i = 1; i <= maxQty; i += 1) {
          const opt = document.createElement("option");
          opt.value = String(i);
          opt.textContent = String(i);
          returnQuantitySelect.appendChild(opt);
        }
      }
      if (returnQtyWrap) {
        if (maxQty > 1) {
          returnQtyWrap.classList.remove("hidden");
        } else {
          returnQtyWrap.classList.add("hidden");
        }
      }

      if (returnQuantitySelect) {
        returnQuantitySelect.onchange = () => toggleCouponWarning(meta);
      }
      toggleCouponWarning(meta);
      returnProductModal.classList.remove("hidden");
      returnProductModal.classList.add("flex");
    }
  
    function closeProductReturnModal() {
      if (!returnProductModal) return;
      returnProductModal.classList.add("hidden");
      returnProductModal.classList.remove("flex");
      if (couponReturnWarning) {
        couponReturnWarning.textContent = "";
        couponReturnWarning.classList.add("hidden");
      }
      if (returnQtyWrap) returnQtyWrap.classList.add("hidden");
      if (returnQuantitySelect) {
        returnQuantitySelect.innerHTML = '<option value="1">1</option>';
      }
    }


    returnProduct.forEach(button => {
        button.addEventListener("click", () => {
          const meta = {
            code: button.dataset.couponCode || "",
            minPurchase: Number(button.dataset.couponMin || 0),
            couponDiscount: Number(button.dataset.couponDiscount || 0),
            activeSubtotal: Number(button.dataset.activeSubtotal || 0),
            unitPrice: Number(button.dataset.unitPrice || 0),
            maxQty: Number(button.dataset.maxQty || 1)
          };
          openProductReturnModal(button.dataset.action, meta);
        });
    });

    if (closeProductReturn) {
      closeProductReturn.addEventListener("click", () => {
        closeProductReturnModal();
      });
    }


    document.querySelectorAll("input[name='reason2']").forEach(radio => {
      radio.addEventListener("change", () => {
        if (productReasonOther && productReasonOther.checked && productCustomReason) {
          productCustomReason.classList.remove("hidden");
        } else if (productCustomReason) {
          productCustomReason.classList.add("hidden");
          productCustomReason.value = "";
        }
      });
    });
  })();
</script>
