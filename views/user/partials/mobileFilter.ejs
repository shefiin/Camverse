<div class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-300 flex justify-around items-center py-2 px-10 z-50 md:hidden">
  <button id="sortBtn" class="flex flex-col items-center text-sm font-extralight text-gray-500 hover:text-teal-600">
    <i class="fa fa-sort"></i>
    SORT
  </button>
  <div class="h-6 w-px bg-gray-300"></div>
  <button id="filterBtn" class="flex flex-col items-center text-sm font-extralight text-gray-500 hover:text-teal-600">
    <i class="fa-solid fa-sliders"></i>
    FILTER
  </button>
</div>

<div id="sortDrawer" class="fixed bottom-0 left-0 right-0 h-[45vh] bg-white border-t z-50 hidden md:hidden">
  <div class="flex justify-between items-center px-4 py-3 bg-white border-b border-gray-300">
    <h2 class="text-lg font-semibold text-gray-800">SORT BY</h2>
    <button id="closeSortBtn" class="text-gray-500 text-xl">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="p-4 overflow-y-auto h-[calc(100%-108px)]" style="accent-color: #00A69D;">
    <div class="space-y-3 text-sm text-gray-700">
      <label class="flex items-center gap-2">
        <input type="radio" name="mobileSort" value="" <%= !queryParams.sort ? "checked" : "" %>>
        Relevance
      </label>
      <label class="flex items-center gap-2">
        <input type="radio" name="mobileSort" value="price_asc" <%= queryParams.sort === "price_asc" ? "checked" : "" %>>
        Price: Low to High
      </label>
      <label class="flex items-center gap-2">
        <input type="radio" name="mobileSort" value="price_desc" <%= queryParams.sort === "price_desc" ? "checked" : "" %>>
        Price: High to Low
      </label>
      <label class="flex items-center gap-2">
        <input type="radio" name="mobileSort" value="alpha_asc" <%= queryParams.sort === "alpha_asc" ? "checked" : "" %>>
        Alphabetically: A-Z
      </label>
      <label class="flex items-center gap-2">
        <input type="radio" name="mobileSort" value="alpha_desc" <%= queryParams.sort === "alpha_desc" ? "checked" : "" %>>
        Alphabetically: Z-A
      </label>
    </div>
  </div>

  <div class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-300 flex justify-around items-center py-3 px-10 z-50 md:hidden">
    <button id="clearSortBtn" type="button" class="flex items-center text-sm font-light text-gray-500 hover:text-red-500 gap-1">
      <i class="fa fa-times"></i>
      CLEAR
    </button>
    <div class="h-6 w-px bg-gray-300"></div>
    <button id="applySortBtn" type="button" class="flex items-center text-sm font-light text-gray-500 hover:text-teal-600 gap-1">
      <i class="fa fa-check"></i>
      APPLY
    </button>
  </div>
</div>

<div id="filterDrawer" class="fixed bottom-0 left-0 right-0 h-[70vh] bg-white border-t z-50 hidden md:hidden">
  <div class="flex justify-between items-center px-4 py-3 bg-white border-b border-gray-300">
    <h2 class="text-lg font-semibold text-gray-800">FILTERS</h2>
    <button id="closeFilterBtn" class="text-gray-500 text-xl">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <form id="mobileFilterForm" method="GET" action="" class="h-[calc(100%-108px)]">
    <% if (queryParams.search) { %>
      <input type="hidden" name="search" value="<%= queryParams.search %>">
    <% } %>
    <% if (queryParams.sort) { %>
      <input type="hidden" name="sort" value="<%= queryParams.sort %>">
    <% } %>

    <div class="flex h-full">
      <div class="w-1/3 bg-gray-100 p-4">
        <p class="text-gray-600 mb-4 cursor-pointer" id="brandBtn">Brand</p>
        <p class="text-gray-600 mb-4 cursor-pointer" id="categoryBtn">Category</p>
        <p class="text-gray-600 mb-4 cursor-pointer" id="priceBtn">Price</p>
      </div>

      <div class="w-2/3 bg-white relative">
        <div id="drawerContent" class="p-4 overflow-y-auto h-full">
          <div id="brandContent" class="hidden">
            <h2 class="border-b border-gray-300 mb-2 font-semibold">BRAND</h2>
            <div class="space-y-2 text-sm font-light" style="accent-color: #00A69D;">
              <% brands.forEach((brand) => { %>
                <label class="flex items-center cursor-pointer hover:text-teal-700">
                  <input
                    type="checkbox"
                    name="brand"
                    value="<%= brand._id %>"
                    class="mr-2"
                    <%= (Array.isArray(queryParams.brand) && queryParams.brand.includes(brand._id.toString())) || queryParams.brand === brand._id.toString() ? "checked" : "" %>
                  >
                  <%= brand.name %>
                </label>
              <% }) %>
            </div>
          </div>

          <div id="categoryContent" class="hidden">
            <h2 class="border-b border-gray-300 mb-2 font-semibold">CATEGORY</h2>
            <div class="space-y-2 text-sm font-light" style="accent-color: #00A69D;">
              <% categories.forEach((category) => { %>
                <label class="flex items-center cursor-pointer hover:text-teal-700">
                  <input
                    type="checkbox"
                    name="category"
                    value="<%= category._id %>"
                    class="mr-2"
                    <%= (Array.isArray(queryParams.category) && queryParams.category.includes(category._id.toString())) || queryParams.category === category._id.toString() ? "checked" : "" %>
                  >
                  <%= category.name %>
                </label>
              <% }) %>
            </div>
          </div>

          <div id="priceContent" class="hidden">
            <h2 class="border-b border-gray-300 mb-2 font-semibold">PRICE</h2>
            <div class="space-y-2 text-sm font-light" style="accent-color: #00A69D;">
              <% priceRanges.forEach((range) => { const rangeValue = `${range.min}-${range.max || ""}`; %>
                <label class="flex items-center cursor-pointer hover:text-teal-700">
                  <input
                    type="checkbox"
                    name="price"
                    value="<%= rangeValue %>"
                    class="mr-2"
                    <%= (Array.isArray(queryParams.price) && queryParams.price.includes(rangeValue)) || queryParams.price === rangeValue ? "checked" : "" %>
                  >
                  <%= range.label %>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-300 flex justify-around items-center py-3 px-10 z-50 md:hidden">
      <button id="clearFilterBtn" type="button" class="flex items-center text-sm font-light text-gray-500 hover:text-red-500 gap-1">
        <i class="fa fa-times"></i>
        CLEAR
      </button>
      <div class="h-6 w-px bg-gray-300"></div>
      <button id="applyFilterBtn" type="submit" class="flex items-center text-sm font-light text-gray-500 hover:text-teal-600 gap-1">
        <i class="fa fa-check"></i>
        APPLY
      </button>
    </div>
  </form>
</div>
