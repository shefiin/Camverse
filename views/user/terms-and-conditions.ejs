<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/fonts.css">
  <title>Camverse</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800" style="font-family:'Open Sans', sans-serif;">
  <%- include('partials/userNavbar', { navbarTheme: 'light' }) %>

  <section class="pt-28 pb-16 px-4 sm:px-6 lg:px-10">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-700 text-white p-8 sm:p-10 shadow-xl mb-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-300">Camverse Policies</p>
        <h1 class="text-3xl sm:text-4xl font-semibold mt-2">Terms & Conditions</h1>
        <p class="mt-3 text-sm sm:text-base text-gray-300 font-extralight">
          Please read these terms before using our platform and placing orders.
        </p>
      </div>

      <div class="bg-white shadow-sm border border-gray-100 p-6 sm:p-8 space-y-6">
        <div>
          <h2 class="text-xl font-semibold mb-2">1. Use of Platform</h2>
          <p class="text-gray-600 text-sm sm:text-base font-extralight">By using Camverse, you agree to provide accurate information and use the platform lawfully.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold mb-2">2. Pricing and Availability</h2>
          <p class="text-gray-600 text-sm sm:text-base font-extralight">Prices, offers, and availability can change without prior notice. Orders are subject to stock availability.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold mb-2">3. Orders and Payments</h2>
          <p class="text-gray-600 text-sm sm:text-base font-extralight">Orders are confirmed only after successful processing. Payment methods are available as shown at checkout.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold mb-2">4. Returns and Refunds</h2>
          <p class="text-gray-600 text-sm sm:text-base font-extralight">Return and refund handling follows the active policy pages and order-level eligibility rules.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold mb-2">5. Account Responsibility</h2>
          <p class="text-gray-600 text-sm sm:text-base font-extralight">You are responsible for maintaining account confidentiality and activity under your account.</p>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/userFooter') %>
  <script src="/js/user/homePage.js"></script>
</body>
</html>
